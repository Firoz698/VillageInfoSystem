@model List<VillageInfoSystem.Models.News>
@{
    ViewData["Title"] = "সংবাদ ব্যবস্থাপনা";
    Layout = "_AdminLayout";
    int activeCount = Model.Count(n => n.IsActive);
    int featuredCount = Model.Count(n => n.IsFeatured);
}

<style>
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ph-left h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: var(--green-dark);
        font-weight: 900;
    }

    .ph-left p {
        font-size: 0.84rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* Stats strip */
    .news-stats {
        display: flex;
        gap: 0.9rem;
        margin-bottom: 1.4rem;
        flex-wrap: wrap;
    }

    .ns-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.52rem 1rem;
        background: white;
        border: 1px solid var(--border);
        border-radius: 50px;
        font-size: 0.82rem;
        color: var(--text-muted);
        box-shadow: var(--shadow-sm);
    }

        .ns-pill strong {
            color: var(--green-dark);
            font-size: 0.97rem;
            font-weight: 800;
        }

    /* Search/filter bar */
    .filter-bar {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 0.85rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
        box-shadow: var(--shadow-sm);
    }

    .search-wrap {
        flex: 1;
        min-width: 200px;
        position: relative;
    }

        .search-wrap input {
            width: 100%;
            padding: 0.6rem 0.9rem 0.6rem 2.4rem;
            border: 1.5px solid var(--border);
            border-radius: 9px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 0.88rem;
            transition: all 0.2s;
        }

            .search-wrap input:focus {
                outline: none;
                border-color: var(--green);
                box-shadow: 0 0 0 3px rgba(26,107,60,0.08);
            }

    .search-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.85rem;
        pointer-events: none;
    }

    .filter-select {
        padding: 0.6rem 0.85rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        font-family: 'Hind Siliguri', sans-serif;
        font-size: 0.85rem;
        color: var(--text);
        cursor: pointer;
        transition: all 0.2s;
        background: white;
    }

        .filter-select:focus {
            outline: none;
            border-color: var(--green);
        }

    /* Table card */
    .table-card {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .tc-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.4rem;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 0.7rem;
    }

    .tc-title {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 700;
        color: var(--green-dark);
        font-size: 0.95rem;
    }

    .tc-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        background: var(--green-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }

    .table-wrap {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.865rem;
    }

    thead th {
        background: #f5f8f5;
        color: var(--green-dark);
        padding: 0.75rem 1rem;
        text-align: left;
        font-weight: 700;
        font-size: 0.76rem;
        letter-spacing: 0.04em;
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
    }

    tbody td {
        padding: 0.8rem 1rem;
        border-bottom: 1px solid #f2f6f2;
        vertical-align: middle;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover td {
        background: #f8fbf8;
    }

    tbody tr.filtered-out {
        display: none;
    }

    /* News icon cell */
    .news-icon-cell {
        font-size: 1.5rem;
        line-height: 1;
    }

    /* Title cell */
    .news-title-cell {
        max-width: 260px;
    }

    .news-title-text {
        font-weight: 600;
        color: var(--text);
        font-size: 0.875rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

    .news-title-desc {
        font-size: 0.75rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        margin-top: 1px;
    }

    /* Actions */
    .actions-cell {
        display: flex;
        gap: 0.45rem;
        align-items: center;
        white-space: nowrap;
    }

    /* Empty state */
    .empty-row td {
        text-align: center;
        padding: 3.5rem 1rem;
        color: var(--text-muted);
    }

    .empty-row .er-icon {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.7rem;
        opacity: 0.4;
    }

    @@media (max-width: 700px) {
        .hide-mobile {
            display: none;
        }

        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-select {
            width: 100%;
        }
    }
</style>

<!-- Header -->
<div class="page-header">
    <div class="ph-left">
        <h2>📰 সংবাদ ব্যবস্থাপনা</h2>
        <p>গ্রামের সকল সংবাদ পরিচালনা করুন</p>
    </div>
    <a href="/Admin/NewsCreate" class="btn btn-primary">➕ নতুন সংবাদ যোগ</a>
</div>

<!-- Stats -->
@if (Model.Any())
{
    <div class="news-stats">
        <div class="ns-pill">📰 মোট: <strong>@Model.Count</strong></div>
        <div class="ns-pill">✅ সক্রিয়: <strong>@activeCount</strong></div>
        <div class="ns-pill">⭐ শীর্ষ: <strong>@featuredCount</strong></div>
        @if (Model.Count - activeCount > 0)
        {
            <div class="ns-pill">⏸️ নিষ্ক্রিয়: <strong>@(Model.Count - activeCount)</strong></div>
        }
    </div>
}

<!-- Filter bar -->
<div class="filter-bar">
    <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" id="searchInput" placeholder="সংবাদ খুঁজুন..." oninput="filterTable()" />
    </div>
    <select class="filter-select" id="catFilter" onchange="filterTable()">
        <option value="">সব বিভাগ</option>
        <option>সাধারণ</option>
        <option>শিক্ষা</option>
        <option>উন্নয়ন</option>
        <option>কৃষি</option>
        <option>স্বাস্থ্য</option>
        <option>ধর্মীয়</option>
        <option>খেলাধুলা</option>
        <option>সংস্কৃতি</option>
    </select>
    <select class="filter-select" id="statusFilter" onchange="filterTable()">
        <option value="">সব অবস্থা</option>
        <option value="active">সক্রিয়</option>
        <option value="inactive">নিষ্ক্রিয়</option>
        <option value="featured">শীর্ষ সংবাদ</option>
    </select>
</div>

<!-- Table -->
<div class="table-card">
    <div class="tc-header">
        <div class="tc-title">
            <div class="tc-icon">📋</div>
            সকল সংবাদ
            <span class="badge badge-gold" id="visibleCount">@Model.Count টি</span>
        </div>
    </div>
    <div class="table-wrap">
        <table id="newsTable">
            <thead>
                <tr>
                    <th style="width:48px">আইকন</th>
                    <th>শিরোনাম</th>
                    <th class="hide-mobile">বিভাগ</th>
                    <th class="hide-mobile">তারিখ</th>
                    <th style="width:50px">শীর্ষ</th>
                    <th>অবস্থা</th>
                    <th style="width:160px">কার্যক্রম</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var n in Model)
                    {
                        <tr data-title="@n.Title.ToLower()"
                            data-cat="@n.Category"
                            data-active="@n.IsActive.ToString().ToLower()"
                            data-featured="@n.IsFeatured.ToString().ToLower()">
                            <td><div class="news-icon-cell">@n.Icon</div></td>
                            <td class="news-title-cell">
                                <span class="news-title-text" title="@n.Title">@n.Title</span>
                                @if (!string.IsNullOrEmpty(n.Description))
                                {
                                    <span class="news-title-desc">@(n.Description.Length > 55 ? n.Description.Substring(0, 55) + "…" : n.Description)</span>
                                }
                            </td>
                            <td class="hide-mobile">
                                <span class="badge badge-gold">@n.Category</span>
                            </td>
                            <td class="hide-mobile" style="color:var(--text-muted);font-size:0.8rem;white-space:nowrap;">
                                @n.PublishedAt.ToString("dd MMM yyyy")
                            </td>
                            <td style="text-align:center">
                                @(n.IsFeatured ? "⭐" : "<span style='color:#ccc'>—</span>")
                            </td>
                            <td>
                                <span class="badge @(n.IsActive ? "badge-success" : "badge-danger")">
                                    @(n.IsActive ? "✓ সক্রিয়" : "✗ নিষ্ক্রিয়")
                                </span>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <a href="/Admin/NewsEdit/@n.Id" class="btn btn-edit btn-sm">✏️ সম্পাদনা</a>
                                    <form method="post" action="/Admin/NewsDelete/@n.Id"
                                          style="display:inline;"
                                          onsubmit="return confirm('এই সংবাদ মুছে ফেলবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr class="empty-row">
                        <td colspan="7">
                            <span class="er-icon">📭</span>
                            এখনো কোনো সংবাদ যোগ করা হয়নি।
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const cat = document.getElementById('catFilter').value;
        const status = document.getElementById('statusFilter').value;
        const rows = document.querySelectorAll('#newsTable tbody tr:not(.empty-row)');
        let visible = 0;
        rows.forEach(row => {
            const titleMatch = !search || row.dataset.title.includes(search);
            const catMatch = !cat || row.dataset.cat === cat;
            let statusMatch = true;
            if (status === 'active') statusMatch = row.dataset.active === 'true';
            else if (status === 'inactive') statusMatch = row.dataset.active === 'false';
            else if (status === 'featured') statusMatch = row.dataset.featured === 'true';
            const show = titleMatch && catMatch && statusMatch;
            row.classList.toggle('filtered-out', !show);
            if (show) visible++;
        });
        const vc = document.getElementById('visibleCount');
        if (vc) vc.textContent = visible + ' টি';
    }
</script>
