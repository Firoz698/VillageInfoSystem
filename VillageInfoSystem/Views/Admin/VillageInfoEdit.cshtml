@model VillageInfoSystem.Models.VillageInfo
@{
    ViewData["Title"] = "গ্রামের তথ্য সম্পাদনা";
    Layout = "_AdminLayout";
}

<style>
    :root {
        --primary: #1a3a5c;
        --primary-light: #2563a8;
        --green: #1a6b3c;
        --green-soft: #ecfdf3;
        --green-border: #a7e6c3;
        --surface: #ffffff;
        --surface-alt: #f5f7fa;
        --border: #dde3ec;
        --border-focus: #2563a8;
        --text-main: #1a2636;
        --text-muted: #5a6b80;
        --shadow-sm: 0 2px 8px rgba(26,58,92,0.07);
        --shadow-md: 0 8px 28px rgba(26,58,92,0.11);
        --radius: 14px;
        --input-radius: 8px;
    }

    .page-wrapper {
        max-width: 860px;
        animation: fadeUp 0.42s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Page title ── */
    .page-heading {
        margin-bottom: 1.75rem;
    }

        .page-heading h1 {
            font-family: 'Noto Serif Bengali', Georgia, serif;
            font-size: 1.55rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0 0 0.25rem;
        }

        .page-heading p {
            font-size: 0.83rem;
            color: var(--text-muted);
            margin: 0;
        }

    /* ── Section cards ── */
    .section-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 1.25rem;
        transition: box-shadow 0.2s;
    }

        .section-card:focus-within {
            box-shadow: var(--shadow-md);
        }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface-alt);
    }

    .section-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .icon-blue {
        background: linear-gradient(135deg, #dde8f8, #c5d7f4);
    }

    .icon-green {
        background: linear-gradient(135deg, #d4f0e2, #b5e4cc);
    }

    .icon-amber {
        background: linear-gradient(135deg, #fef3cd, #fde59a);
    }

    .icon-slate {
        background: linear-gradient(135deg, #e4e9f2, #d0d9ea);
    }

    .section-header-text h3 {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--primary);
        margin: 0;
    }

    .section-header-text p {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0.1rem 0 0;
    }

    .section-body {
        padding: 1.4rem;
    }

    /* ── Form grids ── */
    .form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .form-grid-4 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    /* ── Form elements ── */
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.38rem;
    }

        .form-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

    .form-control {
        width: 100%;
        padding: 0.6rem 0.88rem;
        border: 1.5px solid var(--border);
        border-radius: var(--input-radius);
        font-size: 0.875rem;
        color: var(--text-main);
        background: var(--surface);
        outline: none;
        box-sizing: border-box;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }

        .form-control:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(37,99,168,0.11);
            background: #fafcff;
        }

        .form-control::placeholder {
            color: #b0bcc8;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 130px;
        line-height: 1.65;
    }

    .form-hint {
        font-size: 0.73rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* ── Input with icon ── */
    .input-icon-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

        .input-icon-wrap .input-icon {
            position: absolute;
            left: 0.82rem;
            color: var(--text-muted);
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .input-icon-wrap .form-control {
            padding-left: 2.35rem;
        }

    /* ── Stat input special style ── */
    .stat-input-wrap {
        position: relative;
    }

        .stat-input-wrap .stat-unit {
            position: absolute;
            right: 0.85rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.73rem;
            color: var(--text-muted);
            font-weight: 500;
            pointer-events: none;
            background: var(--surface);
            padding-left: 4px;
        }

        .stat-input-wrap .form-control {
            padding-right: 3.5rem;
        }

    /* ── Population visual bar ── */
    .pop-ratio-bar {
        margin-top: 0.9rem;
        padding: 0.9rem 1rem;
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 9px;
    }

    .pop-ratio-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .pop-bar-track {
        height: 8px;
        background: #e4e9f2;
        border-radius: 999px;
        overflow: hidden;
    }

    .pop-bar-male {
        height: 100%;
        background: linear-gradient(90deg, #2563a8, #4a90d9);
        border-radius: 999px 0 0 999px;
        transition: width 0.5s ease;
    }

    .pop-bar-legend {
        display: flex;
        gap: 1.2rem;
        margin-top: 0.5rem;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.73rem;
        color: var(--text-muted);
    }

    .legend-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-male {
        background: #2563a8;
    }

    .dot-female {
        background: #e16b8c;
    }

    /* ── Map preview ── */
    .map-preview-link {
        margin-top: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.78rem;
        color: var(--primary-light);
        text-decoration: none;
        font-weight: 500;
        opacity: 0;
        transition: opacity 0.2s;
    }

        .map-preview-link.visible {
            opacity: 1;
        }

        .map-preview-link:hover {
            text-decoration: underline;
        }

    /* ── Save bar (sticky) ── */
    .save-bar {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid var(--border);
        border-radius: 0 0 var(--radius) var(--radius);
        padding: 1rem 1.4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 0;
        box-shadow: 0 -4px 20px rgba(26,58,92,0.08);
    }

    .save-bar-hint {
        font-size: 0.78rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .save-bar-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--primary);
        color: #fff;
        border: none;
        padding: 0.65rem 1.5rem;
        border-radius: 9px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(26,58,92,0.2);
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }

        .btn-primary:hover {
            background: var(--primary-light);
            transform: translateY(-1px);
            box-shadow: 0 5px 18px rgba(26,58,92,0.24);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

    .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        color: var(--text-muted);
        border: 1.5px solid var(--border);
        padding: 0.6rem 1.25rem;
        border-radius: 9px;
        font-size: 0.88rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

        .btn-outline:hover {
            color: var(--text-main);
            border-color: #b0bcc8;
            background: #eef1f5;
        }

    /* ── Divider ── */
    .form-divider {
        border: none;
        border-top: 1px dashed var(--border);
        margin: 1.1rem 0;
    }

    /* ── Responsive ── */
    @@media (max-width: 720px) {
        .form-grid-2 {
            grid-template-columns: 1fr;
        }

        .form-grid-3 {
            grid-template-columns: 1fr 1fr;
        }

        .form-grid-4 {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .form-grid-3 {
            grid-template-columns: 1fr;
        }

        .section-body {
            padding: 1.1rem;
        }

        .section-header {
            padding: 0.9rem 1.1rem;
        }

        .save-bar {
            padding: 0.9rem 1.1rem;
            flex-direction: column-reverse;
            align-items: stretch;
        }

        .save-bar-actions {
            flex-direction: column;
        }

        .btn-primary, .btn-outline {
            justify-content: center;
        }

        .page-heading h1 {
            font-size: 1.3rem;
        }
    }
</style>

<div class="page-wrapper">

    <!-- Page heading -->
    <div class="page-heading">
        <h1>গ্রামের মূল তথ্য সম্পাদনা</h1>
        <p>নিচের বিভাগগুলো পূরণ করে গ্রামের সম্পূর্ণ তথ্য আপডেট করুন</p>
    </div>

    <form asp-action="VillageInfoEdit" method="post" id="villageForm">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <!-- ── Section 1: Basic Info ── -->
        <div class="section-card">
            <div class="section-header">
                <div class="section-icon icon-blue">📍</div>
                <div class="section-header-text">
                    <h3>মৌলিক তথ্য</h3>
                    <p>গ্রামের নাম, বিভাগ ও ইতিহাস</p>
                </div>
            </div>
            <div class="section-body">
                <div class="form-grid-2" style="margin-bottom:1rem">
                    <div class="form-group">
                        <label asp-for="VillageName">গ্রামের নাম</label>
                        <input asp-for="VillageName" class="form-control" placeholder="গ্রামের সম্পূর্ণ নাম" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Division">বিভাগ / জেলা</label>
                        <input asp-for="Division" class="form-control" placeholder="যেমন: খুলনা বিভাগ" autocomplete="off" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="History">গ্রামের ইতিহাস ও পরিচিতি</label>
                    <textarea asp-for="History" class="form-control" placeholder="গ্রামের সংক্ষিপ্ত ইতিহাস, বৈশিষ্ট্য ও পটভূমি লিখুন…"></textarea>
                </div>
            </div>
        </div>

        <!-- ── Section 2: Statistics ── -->
        <div class="section-card">
            <div class="section-header">
                <div class="section-icon icon-green">📊</div>
                <div class="section-header-text">
                    <h3>জনসংখ্যা ও পরিসংখ্যান</h3>
                    <p>গ্রামের জনমিতিক তথ্য ও পরিসংখ্যান</p>
                </div>
            </div>
            <div class="section-body">
                <div class="form-grid-3" style="margin-bottom:1rem">
                    <div class="form-group">
                        <label asp-for="TotalPopulation">মোট জনসংখ্যা</label>
                        <div class="stat-input-wrap">
                            <input asp-for="TotalPopulation" type="number" class="form-control" placeholder="0" min="0" id="totalPop" oninput="updatePopBar()" />
                            <span class="stat-unit">জন</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="TotalFamilies">মোট পরিবার</label>
                        <div class="stat-input-wrap">
                            <input asp-for="TotalFamilies" type="number" class="form-control" placeholder="0" min="0" />
                            <span class="stat-unit">টি</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Area">আয়তন</label>
                        <div class="stat-input-wrap">
                            <input asp-for="Area" class="form-control" placeholder="0.00" />
                            <span class="stat-unit">বর্গ কি.মি.</span>
                        </div>
                    </div>
                </div>

                <div class="form-grid-3">
                    <div class="form-group">
                        <label asp-for="MalePopulation">পুরুষ</label>
                        <div class="stat-input-wrap">
                            <input asp-for="MalePopulation" type="number" class="form-control" placeholder="0" min="0" id="malePop" oninput="updatePopBar()" />
                            <span class="stat-unit">জন</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="FemalePopulation">মহিলা</label>
                        <div class="stat-input-wrap">
                            <input asp-for="FemalePopulation" type="number" class="form-control" placeholder="0" min="0" id="femalePop" oninput="updatePopBar()" />
                            <span class="stat-unit">জন</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="LiteracyRate">সাক্ষরতার হার</label>
                        <div class="stat-input-wrap">
                            <input asp-for="LiteracyRate" class="form-control" placeholder="0" />
                            <span class="stat-unit">%</span>
                        </div>
                    </div>
                </div>

                <!-- Population ratio bar -->
                <div class="pop-ratio-bar" id="popRatioBar" style="display:none">
                    <div class="pop-ratio-label">
                        <span>লিঙ্গ অনুপাত</span>
                        <span id="ratioText">—</span>
                    </div>
                    <div class="pop-bar-track">
                        <div class="pop-bar-male" id="maleBar" style="width:50%"></div>
                    </div>
                    <div class="pop-bar-legend">
                        <div class="legend-item"><span class="legend-dot dot-male"></span> পুরুষ <span id="malePct" style="margin-left:0.15rem">—</span></div>
                        <div class="legend-item"><span class="legend-dot dot-female"></span> মহিলা <span id="femalePct" style="margin-left:0.15rem">—</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 3: Contact ── -->
        <div class="section-card">
            <div class="section-header">
                <div class="section-icon icon-amber">📞</div>
                <div class="section-header-text">
                    <h3>যোগাযোগ ও অফিস তথ্য</h3>
                    <p>ঠিকানা, ফোন, ইমেইল ও সামাজিক মাধ্যম</p>
                </div>
            </div>
            <div class="section-body">
                <div class="form-group" style="margin-bottom:1rem">
                    <label asp-for="Address">পূর্ণ ঠিকানা</label>
                    <div class="input-icon-wrap">
                        <span class="input-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                        </span>
                        <input asp-for="Address" class="form-control" placeholder="গ্রাম, পোস্ট অফিস, উপজেলা, জেলা" />
                    </div>
                </div>

                <div class="form-grid-4" style="margin-bottom:1rem">
                    <div class="form-group">
                        <label asp-for="Phone">ফোন নম্বর</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.61 4.9 2 2 0 0 1 3.59 2.72h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.4a16 16 0 0 0 6.29 6.29l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                            </span>
                            <input asp-for="Phone" class="form-control" type="tel" placeholder="০১৭১২-XXXXXX" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Email">ইমেইল</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                            </span>
                            <input asp-for="Email" class="form-control" type="email" placeholder="office@village.com" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Facebook">ফেসবুক পেজ</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon" style="font-size:0.85rem">f</span>
                            <input asp-for="Facebook" class="form-control" placeholder="facebook.com/..." />
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="OfficeHours">অফিস সময়</label>
                        <div class="input-icon-wrap">
                            <span class="input-icon">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                            </span>
                            <input asp-for="OfficeHours" class="form-control" placeholder="সকাল ৯টা – বিকাল ৫টা" />
                        </div>
                    </div>
                </div>

                <hr class="form-divider" />

                <div class="form-group">
                    <label asp-for="MapsLink">গুগল ম্যাপস লিংক</label>
                    <div class="input-icon-wrap">
                        <span class="input-icon">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
                        </span>
                        <input asp-for="MapsLink" class="form-control" placeholder="https://maps.google.com/..." id="mapsInput" oninput="updateMapLink(this)" />
                    </div>
                    <a id="mapPreviewLink" class="map-preview-link" href="#" target="_blank" rel="noopener">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
                        ম্যাপে দেখুন
                    </a>
                </div>
            </div>
        </div>

        <!-- ── Sticky Save Bar ── -->
        <div class="save-bar">
            <div class="save-bar-hint">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                পরিবর্তন সংরক্ষণ না করলে হারিয়ে যাবে
            </div>
            <div class="save-bar-actions">
                <a href="/Admin/Dashboard" class="btn-outline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
                    বাতিল
                </a>
                <button type="submit" class="btn-primary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                    পরিবর্তন সংরক্ষণ করুন
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    function updatePopBar() {
        const male   = parseInt(document.getElementById('malePop').value)   || 0;
        const female = parseInt(document.getElementById('femalePop').value) || 0;
        const total  = male + female;
        const bar    = document.getElementById('popRatioBar');

        if (total === 0) { bar.style.display = 'none'; return; }

        bar.style.display = 'block';
        const malePct   = Math.round((male   / total) * 100);
        const femalePct = 100 - malePct;

        document.getElementById('maleBar').style.width   = malePct + '%';
        document.getElementById('malePct').textContent   = malePct + '%';
        document.getElementById('femalePct').textContent = femalePct + '%';
        document.getElementById('ratioText').textContent = `${male.toLocaleString()} : ${female.toLocaleString()}`;
    }

    function updateMapLink(input) {
        const link = document.getElementById('mapPreviewLink');
        const val  = input.value.trim();
        if (val && val.startsWith('http')) {
            link.href = val;
            link.classList.add('visible');
        } else {
            link.classList.remove('visible');
        }
    }

    // Init on load
    updatePopBar();
    const mapsInput = document.getElementById('mapsInput');
    if (mapsInput && mapsInput.value) updateMapLink(mapsInput);

    // Warn on unsaved changes
    let formDirty = false;
    document.getElementById('villageForm').addEventListener('input', () => formDirty = true);
    document.getElementById('villageForm').addEventListener('submit', () => formDirty = false);
    window.addEventListener('beforeunload', e => {
        if (formDirty) {
            e.preventDefault();
            e.returnValue = '';
        }
    });
</script>
