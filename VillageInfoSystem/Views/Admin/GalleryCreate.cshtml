@model VillageInfoSystem.Models.GalleryItem
@{
    ViewData["Title"] = "নতুন গ্যালারি আইটেম";
    Layout = "_AdminLayout";
}
<div class="breadcrumb"><a href="/Admin/GalleryList">গ্যালারি</a> › নতুন</div>
<div class="card" style="max-width:650px">
    <div class="card-title" style="margin-bottom:1.2rem">🖼️ নতুন গ্যালারি আইটেম</div>
    <form asp-action="GalleryCreate" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group"><label asp-for="Title"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" style="color:red;font-size:0.82rem"></span></div>
            <div class="form-group"><label asp-for="Icon"></label><input asp-for="Icon" class="form-control" placeholder="🕌" /></div>
        </div>
        <div class="form-group">
            <label>ছবি আপলোড (ঐচ্ছিক)</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
            <small style="color:#888;font-size:0.8rem;">ছবি না থাকলে নিচের রং ব্যবহার হবে</small>
        </div>
        <div class="form-group">
            <label asp-for="GradientColor"></label>
            <input asp-for="GradientColor" class="form-control" placeholder="linear-gradient(135deg, #2d9b5a, #1a6b3c)" />
            <small style="color:#888;font-size:0.8rem;">CSS gradient কোড দিন</small>
        </div>
        <div class="form-grid">
            <div class="form-group"><label asp-for="SortOrder"></label><input asp-for="SortOrder" type="number" class="form-control" /></div>
            <div class="form-group" style="display:flex;align-items:center;gap:1.5rem;padding-top:1.8rem">
                <div class="form-check"><input asp-for="IsFeatured" type="checkbox" /><label asp-for="IsFeatured">ফিচার্ড</label></div>
                <div class="form-check"><input asp-for="IsActive" type="checkbox" /><label asp-for="IsActive">সক্রিয়</label></div>
            </div>
        </div>
        <div style="display:flex;gap:1rem"><button type="submit" class="btn btn-primary">💾 সংরক্ষণ</button><a href="/Admin/GalleryList" class="btn btn-outline">বাতিল</a></div>
    </form>
</div>
