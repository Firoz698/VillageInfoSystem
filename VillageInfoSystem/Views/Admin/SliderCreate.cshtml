</div>

<script>
    /* ═══════════════════════════════════════
       DS — Dropdown Selector module
    ═══════════════════════════════════════ */
    const DS = (() => {
        function close(id) {
            document.getElementById(`p-${id}`)?.classList.remove('is-open');
            document.getElementById(`t-${id}`)?.classList.remove('is-open');
        }

        function toggle(id) {
            const panel   = document.getElementById(`p-${id}`);
            const trigger = document.getElementById(`t-${id}`);
            // Close all others
            document.querySelectorAll('.ds-panel.is-open').forEach(p => {
                if (p !== panel) {
                    p.classList.remove('is-open');
                    const tid = p.id.replace('p-','t-');
                    document.getElementById(tid)?.classList.remove('is-open');
                }
            });
            const opening = !panel.classList.contains('is-open');
            panel.classList.toggle('is-open', opening);
            trigger.classList.toggle('is-open', opening);
            if (opening) {
                const s = panel.querySelector('.ds-search');
                if (s) setTimeout(() => s.focus(), 60);
            }
        }

        function setValue(id, value, icon) {
            document.getElementById(`h-${id}`).value = value;
            const lbl = document.getElementById(`t-${id}-lbl`);
            lbl.textContent = value;
            lbl.classList.remove('muted');
            document.getElementById(`t-${id}-ico`).textContent = icon || '✅';
        }

        function markActive(id, value) {
            document.querySelectorAll(`#l-${id} .ds-opt`).forEach(o => {
                const nameEl = o.querySelector('.ds-opt-name');
                o.classList.toggle('chosen', nameEl?.textContent.trim() === value);
            });
        }

        function pick(id, value, icon, previewId) {
            setValue(id, value, icon);
            markActive(id, value);
            close(id);
            if (previewId) {
                const el = document.getElementById(previewId);
                if (el) el.textContent = value;
                updateBtnRow();
            }
        }

        function custom(id, previewId) {
            const input = document.getElementById(`ci-${id}`);
            const val   = input.value.trim();
            if (!val) { input.focus(); return; }
            setValue(id, val, '✏️');
            markActive(id, ''); // deselect all
            close(id);
            input.value = '';
            if (previewId) {
                const el = document.getElementById(previewId);
                if (el) el.textContent = val;
                updateBtnRow();
            }
        }

        function filter(id, q) {
            const lq = q.toLowerCase();
            document.querySelectorAll(`#l-${id} .ds-opt`).forEach(o => {
                o.style.display = o.textContent.toLowerCase().includes(lq) ? '' : 'none';
            });
        }

        return { toggle, pick, custom, filter };
    })();

    /* Close when clicking outside */
    document.addEventListener('click', e => {
        if (!e.target.closest('.ds-wrap')) {
            document.querySelectorAll('.ds-panel.is-open').forEach(p => {
                p.classList.remove('is-open');
                const tid = p.id.replace('p-','t-');
                document.getElementById(tid)?.classList.remove('is-open');
            });
        }
    });

    /* Preview btn row visibility */
    function updateBtnRow() {
        const b1  = document.getElementById('h-b1txt')?.value.trim();
        const b2  = document.getElementById('h-b2txt')?.value.trim();
        document.getElementById('prev-btns').style.display = (b1||b2) ? 'flex' : 'none';
    }

    /* Main preview sync */
    function syncPreview() {
        const G = id => document.getElementById(id)?.value.trim();
        document.getElementById('prev-badge').textContent     = G('badgeInput') || 'Badge';
        document.getElementById('prev-title').textContent     = G('titleInput') || 'Title';
        document.getElementById('prev-highlight').textContent = G('highlightInput') || 'Highlight';
        document.getElementById('prev-sub').textContent       = (G('subInput') || 'সাব টেক্সট').substring(0,80);
        updateBtnRow();
    }

    /* Char counter */
    const toB = n => n.toString().replace(/\d/g, d => '০১২৩৪৫৬৭৮৯'[d]);
    function countChars(el, cid, max) {
        const len = el.value.length;
        const c = document.getElementById(cid);
        if (!c) return;
        c.textContent = `${toB(len)}/${toB(max)}`;
        c.className = 'char-count' + (len > max*.8 ? ' near' : '') + (len >= max ? ' over' : '');
    }

    /* Image upload */
    function handleImage(input) {
        if (!input.files?.[0]) return;
        const file = input.files[0];
        if (file.size > 5*1024*1024) { alert('ফাইলের সাইজ ৫MB-এর বেশি হওয়া যাবে না।'); input.value=''; return; }
        const reader = new FileReader();
        reader.onload = e => {
            const src = e.target.result;
            document.getElementById('imgPreview').src = src;
            document.getElementById('previewWrap').classList.add('show');
            document.getElementById('uploadZone').style.display = 'none';
            const bg = document.getElementById('slideBg');
            bg.style.backgroundImage = `url('${src}')`;
            bg.classList.add('show');
            document.getElementById('noImgPh').classList.add('hidden');
            document.getElementById('imgFileName').textContent = file.name;
        };
        reader.readAsDataURL(file);
    }

    function removeImage() {
        document.getElementById('imageInput').value = '';
        document.getElementById('imgPreview').src = '';
        document.getElementById('previewWrap').classList.remove('show');
        document.getElementById('uploadZone').style.display = '';
        const bg = document.getElementById('slideBg');
        bg.style.backgroundImage = '';
        bg.classList.remove('show');
        document.getElementById('noImgPh').classList.remove('hidden');
        document.getElementById('imgFileName').textContent = '—';
    }

    /* Drag & Drop */
    const zone = document.getElementById('uploadZone');
    if (zone) {
        zone.addEventListener('dragover',  e => { e.preventDefault(); zone.classList.add('drag-over'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
        zone.addEventListener('drop', e => {
            e.preventDefault(); zone.classList.remove('drag-over');
            if (e.dataTransfer.files.length) {
                document.getElementById('imageInput').files = e.dataTransfer.files;
                handleImage(document.getElementById('imageInput'));
            }
        });
    }

    /* Init */
    syncPreview();
</script>
