@model VillageInfoSystem.Models.SliderItem
@{
    ViewData["Title"] = "নতুন স্লাইড যোগ করুন";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --g900: #0d2918;
        --g800: #1a4a2e;
        --g700: #1e6b3c;
        --g600: #2a8a52;
        --g300: #7bc49a;
        --g100: #e8f5ec;
        --g50: #f2faf5;
        --gold: #c8903a;
        --gold-light: #f0c97a;
        --ink: #111c16;
        --ink-muted: #4a6658;
        --ink-faint: #8aab97;
        --canvas: #ffffff;
        --surface: #f7fbf8;
        --border: #d6e8dd;
        --border-strong: #b8d4c4;
        --shadow-xs: 0 1px 3px rgba(13,41,24,.06);
        --shadow-sm: 0 3px 10px rgba(13,41,24,.08);
        --shadow-md: 0 8px 28px rgba(13,41,24,.11);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    .sc-page {
        animation: scPageIn .5s cubic-bezier(.22,1,.36,1) both;
    }

    @@keyframes scPageIn {
        from {
            opacity: 0;
            transform: translateY(18px)
        }

        to {
            opacity: 1;
            transform: none
        }
    }

    /* Header */
    .sc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .sc-header-title {
        display: flex;
        align-items: center;
        gap: .9rem;
    }

    .sc-header-emblem {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg,var(--g700),var(--g900));
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 4px 14px rgba(13,41,24,.25);
        flex-shrink: 0;
    }

    .sc-header-text h1 {
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--g900);
        margin: 0 0 .2rem;
        letter-spacing: -.02em;
        line-height: 1.15;
    }

    .sc-header-text p {
        font-size: .82rem;
        color: var(--ink-muted);
        margin: 0;
    }

    .sc-back-btn {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem 1.1rem;
        border: 1.5px solid var(--border-strong);
        border-radius: var(--radius-sm);
        font-size: .82rem;
        font-weight: 600;
        color: var(--ink-muted);
        background: var(--canvas);
        text-decoration: none;
        transition: all .18s;
        white-space: nowrap;
    }

        .sc-back-btn:hover {
            border-color: var(--g600);
            color: var(--g700);
            background: var(--g50);
        }

    /* Layout */
    .sc-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 1.5rem;
        align-items: start;
    }

    /* Sections */
    .sc-section {
        background: var(--canvas);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: visible; /* FIXED: was 'hidden', caused dropdown clipping */
        margin-bottom: 1.2rem;
        transition: box-shadow .2s;
    }

        .sc-section:focus-within {
            box-shadow: var(--shadow-md);
        }

        .sc-section:last-child {
            margin-bottom: 0;
        }

    .sc-section-head {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0; /* FIXED: re-add top radius since overflow:visible */
    }

    .sc-section-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .icon-tag {
        background: linear-gradient(135deg,#daeee4,#bcdece);
    }

    .icon-link {
        background: linear-gradient(135deg,#dde8f8,#c5d7f4);
    }

    .icon-image {
        background: linear-gradient(135deg,#fde8d8,#fac9ad);
    }

    .sc-section-head-text h3 {
        font-size: .9rem;
        font-weight: 700;
        color: var(--g900);
        margin: 0 0 .1rem;
    }

    .sc-section-head-text p {
        font-size: .74rem;
        color: var(--ink-muted);
        margin: 0;
    }

    .sc-section-body {
        padding: 1.3rem 1.4rem;
    }

    /* Form */
    .fg-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: .38rem;
        margin-bottom: 1rem;
    }

        .form-group:last-child {
            margin-bottom: 0;
        }

    .form-label {
        font-size: .79rem;
        font-weight: 700;
        color: var(--g900);
        display: flex;
        align-items: center;
        gap: .3rem;
        letter-spacing: .01em;
    }

    .req {
        color: #d04040;
        font-size: .72rem;
    }

    .form-control {
        width: 100%;
        padding: .62rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: .875rem;
        color: var(--ink);
        background: var(--canvas);
        outline: none;
        box-sizing: border-box;
        font-family: inherit;
        transition: border-color .18s, box-shadow .18s, background .18s;
    }

        .form-control:focus {
            border-color: var(--g600);
            box-shadow: 0 0 0 3px rgba(42,138,82,.12);
            background: #fafffc;
        }

        .form-control::placeholder {
            color: var(--ink-faint);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 88px;
        line-height: 1.6;
    }

    .form-hint {
        font-size: .72rem;
        color: var(--ink-faint);
        display: flex;
        align-items: center;
        gap: .28rem;
        margin-top: .05rem;
    }

    .val-msg {
        font-size: .74rem;
        color: #c0392b;
        margin-top: .18rem;
    }

    .field-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: .22rem;
    }

    .char-count {
        font-size: .7rem;
        color: var(--ink-faint);
    }

        .char-count.near {
            color: #c87a30;
        }

        .char-count.over {
            color: #c03020;
            font-weight: 600;
        }

    /* ═══════════════════════════════
               CUSTOM DROPDOWN SELECTOR
            ═══════════════════════════════ */
    .ds-wrap {
        position: relative;
    }

    .ds-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--canvas);
        cursor: pointer;
        font-family: inherit;
        text-align: left;
        outline: none;
        box-sizing: border-box;
        transition: all .18s;
    }

        .ds-trigger:hover {
            border-color: var(--border-strong);
            background: var(--surface);
        }

        .ds-trigger.is-open {
            border-color: var(--g600);
            box-shadow: 0 0 0 3px rgba(42,138,82,.12);
            background: #fafffc;
        }

    .ds-trigger-left {
        display: flex;
        align-items: center;
        gap: .6rem;
        min-width: 0;
        flex: 1;
    }

    .ds-trigger-icon {
        font-size: 1rem;
        flex-shrink: 0;
        line-height: 1;
    }

    .ds-trigger-label {
        font-size: .875rem;
        color: var(--ink);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .ds-trigger-label.muted {
            color: var(--ink-faint);
        }

    .ds-chevron {
        flex-shrink: 0;
        color: var(--ink-faint);
        transition: transform .2s;
    }

    .ds-trigger.is-open .ds-chevron {
        transform: rotate(180deg);
    }

    /* Panel */
    .ds-panel {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 9999; /* FIXED: increased from 300 to 9999 */
        background: var(--canvas);
        border: 1.5px solid var(--border-strong);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-md);
        overflow: hidden;
        pointer-events: none;
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity .15s, transform .15s;
    }

        .ds-panel.is-open {
            pointer-events: all;
            opacity: 1;
            transform: translateY(0);
        }

    /* Search */
    .ds-search-row {
        padding: .6rem .7rem .4rem;
        border-bottom: 1px solid var(--border);
        position: relative;
    }

        .ds-search-row svg {
            position: absolute;
            left: 1.2rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--ink-faint);
            pointer-events: none;
        }

    .ds-search {
        width: 100%;
        padding: .42rem .7rem .42rem 2rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: .82rem;
        font-family: inherit;
        color: var(--ink);
        outline: none;
        background: var(--surface);
        box-sizing: border-box;
        transition: border-color .15s;
    }

        .ds-search:focus {
            border-color: var(--g600);
        }

    /* Options */
    .ds-list {
        max-height: 200px;
        overflow-y: auto;
        padding: .3rem 0;
    }

        .ds-list::-webkit-scrollbar {
            width: 3px;
        }

        .ds-list::-webkit-scrollbar-thumb {
            background: var(--border-strong);
            border-radius: 99px;
        }

    .ds-opt {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .58rem 1rem;
        cursor: pointer;
        transition: background .13s;
    }

        .ds-opt:hover {
            background: var(--g50);
        }

        .ds-opt.chosen {
            background: var(--g100);
        }

    .ds-opt-ico {
        font-size: .9rem;
        flex-shrink: 0;
        width: 18px;
        text-align: center;
        line-height: 1;
    }

    .ds-opt-body {
        flex: 1;
        min-width: 0;
    }

    .ds-opt-name {
        font-size: .85rem;
        color: var(--ink);
        display: block;
        line-height: 1.3;
    }

    .ds-opt-hint {
        font-size: .7rem;
        color: var(--ink-faint);
        display: block;
        margin-top: .06rem;
    }

    .ds-opt-tick {
        color: var(--g600);
        opacity: 0;
        flex-shrink: 0;
        transition: opacity .15s;
    }

    .ds-opt.chosen .ds-opt-tick {
        opacity: 1;
    }

    /* Custom row */
    .ds-custom-row {
        border-top: 1px solid var(--border);
        background: var(--surface);
        padding: .6rem .7rem;
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }

    .ds-custom-label {
        font-size: .68rem;
        font-weight: 700;
        color: var(--ink-faint);
        text-transform: uppercase;
        letter-spacing: .07em;
    }

    .ds-custom-inputs {
        display: flex;
        gap: .4rem;
    }

    .ds-custom-input {
        flex: 1;
        padding: .4rem .65rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: .82rem;
        font-family: inherit;
        color: var(--ink);
        outline: none;
        background: var(--canvas);
        transition: border-color .15s;
    }

        .ds-custom-input:focus {
            border-color: var(--g600);
        }

        .ds-custom-input::placeholder {
            color: var(--ink-faint);
        }

    .ds-apply {
        padding: .4rem .85rem;
        background: var(--g700);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        white-space: nowrap;
        transition: background .15s;
    }

        .ds-apply:hover {
            background: var(--g600);
        }

    /* Hidden synced input */
    .ds-hidden-input {
        display: none;
    }

    /* Button slots */
    .btn-slots {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .btn-slot {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        padding: 1.1rem;
        overflow: visible; /* FIXED: ensure dropdowns not clipped */
        position: relative;
    }

        .btn-slot:focus-within {
            border-color: var(--g600);
            box-shadow: 0 0 0 3px rgba(42,138,82,.07);
        }

    .btn-slot-head {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .9rem;
    }

    .btn-slot-num {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        background: linear-gradient(135deg,var(--g700),var(--g900));
        color: #fff;
        font-size: .7rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .btn-slot-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--g900);
    }

    .btn-slot .form-group {
        margin-bottom: .75rem;
    }

        .btn-slot .form-group:last-child {
            margin-bottom: 0;
        }

    /* Upload */
    .upload-zone {
        border: 2px dashed var(--border-strong);
        border-radius: var(--radius-md);
        padding: 2rem 1.5rem;
        text-align: center;
        cursor: pointer;
        position: relative;
        background: var(--surface);
        transition: all .22s;
    }

        .upload-zone:hover, .upload-zone.drag-over {
            border-color: var(--g600);
            background: var(--g50);
            transform: translateY(-1px);
            box-shadow: var(--shadow-sm);
        }

        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .uz-icon-wrap {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg,var(--g100),#d0ead8);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto .8rem;
        transition: transform .2s;
    }

    .upload-zone:hover .uz-icon-wrap {
        transform: scale(1.08) rotate(-3deg);
    }

    .uz-main {
        font-size: .875rem;
        color: var(--ink-muted);
        font-weight: 500;
    }

        .uz-main strong {
            color: var(--g700);
        }

    .uz-sub {
        font-size: .72rem;
        color: var(--ink-faint);
        margin-top: .3rem;
    }

    .img-preview-wrap {
        display: none;
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 2px solid var(--border);
        box-shadow: var(--shadow-xs);
    }

        .img-preview-wrap.show {
            display: block;
        }

        .img-preview-wrap img {
            width: 100%;
            max-height: 220px;
            object-fit: cover;
            display: block;
        }

    .img-meta-bar {
        background: var(--surface);
        padding: .55rem .85rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: .75rem;
        color: var(--ink-muted);
        border-top: 1px solid var(--border);
    }

    .img-remove-btn {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: none;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        padding: .22rem .6rem;
        font-size: .72rem;
        color: #c0392b;
        cursor: pointer;
        transition: all .15s;
    }

        .img-remove-btn:hover {
            background: #fff0f0;
            border-color: #f0a0a0;
        }

    /* Sidebar */
    .sc-sidebar {
        position: sticky;
        top: 1.5rem;
    }

    .sc-card {
        background: var(--canvas);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

        .sc-card:last-child {
            margin-bottom: 0;
        }

    .sc-card-head {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .85rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        font-size: .83rem;
        font-weight: 700;
        color: var(--g900);
    }

    .sc-card-body {
        padding: 1.1rem 1.2rem;
    }

    .slide-canvas {
        border-radius: var(--radius-md);
        overflow: hidden;
        height: 180px;
        background: var(--g900);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .slide-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transition: opacity .4s;
    }

        .slide-bg.show {
            opacity: 1;
        }

    .slide-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top,rgba(8,30,18,.88) 0%,rgba(8,30,18,.45) 60%,rgba(8,30,18,.2) 100%);
    }

    .slide-no-img {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: .5rem;
        opacity: .35;
        transition: opacity .3s;
    }

        .slide-no-img.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .slide-no-img svg {
            color: var(--g300);
        }

        .slide-no-img span {
            font-size: .7rem;
            color: var(--g300);
        }

    .slide-content {
        position: relative;
        z-index: 2;
        padding: 1.2rem;
        width: 100%;
    }

    .slide-badge {
        display: inline-block;
        background: rgba(200,144,58,.22);
        border: 1px solid rgba(200,144,58,.45);
        color: #f0c060;
        padding: .12rem .65rem;
        border-radius: 999px;
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .04em;
        margin-bottom: .5rem;
    }

    .slide-title {
        font-size: 1.05rem;
        font-weight: 900;
        color: #fff;
        line-height: 1.2;
        text-shadow: 0 1px 8px rgba(0,0,0,.4);
    }

        .slide-title .hl {
            color: var(--gold-light);
        }

    .slide-sub {
        font-size: .65rem;
        color: rgba(255,255,255,.6);
        margin-top: .4rem;
        line-height: 1.4;
    }

    .slide-btns {
        display: flex;
        gap: .4rem;
        justify-content: center;
        margin-top: .65rem;
    }

    .slide-btn-p {
        padding: .2rem .65rem;
        border-radius: 999px;
        font-size: .55rem;
        font-weight: 700;
        background: var(--g600);
        color: #fff;
    }

    .slide-btn-o {
        padding: .2rem .65rem;
        border-radius: 999px;
        font-size: .55rem;
        font-weight: 700;
        background: transparent;
        border: 1px solid rgba(255,255,255,.4);
        color: rgba(255,255,255,.85);
    }

    .toggle-row {
        display: flex;
        align-items: center;
        gap: .85rem;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .85rem 1rem;
        cursor: pointer;
        transition: all .18s;
    }

        .toggle-row:hover {
            border-color: var(--g600);
            background: var(--g50);
        }

    .ts-switch {
        position: relative;
        width: 42px;
        height: 23px;
        flex-shrink: 0;
    }

        .ts-switch input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }

    .ts-track {
        position: absolute;
        inset: 0;
        background: #ccdad4;
        border-radius: 999px;
        transition: background .22s;
        cursor: pointer;
    }

        .ts-track::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 17px;
            height: 17px;
            background: #fff;
            border-radius: 50%;
            box-shadow: 0 1px 5px rgba(0,0,0,.18);
            transition: transform .22s;
        }

    .ts-switch input:checked ~ .ts-track {
        background: var(--g600);
    }

        .ts-switch input:checked ~ .ts-track::after {
            transform: translateX(19px);
        }

    .ts-info strong {
        display: block;
        font-size: .84rem;
        font-weight: 700;
        color: var(--g900);
    }

    .ts-info span {
        font-size: .73rem;
        color: var(--ink-muted);
    }

    .tip-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        padding: .55rem 0;
        border-bottom: 1px solid var(--border);
        font-size: .77rem;
        color: var(--ink-muted);
        line-height: 1.45;
    }

        .tip-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .tip-item:first-child {
            padding-top: 0;
        }

    .tip-dot {
        width: 5px;
        height: 5px;
        background: var(--g300);
        border-radius: 50%;
        margin-top: .45rem;
        flex-shrink: 0;
    }

    .sc-actions {
        display: flex;
        flex-direction: column;
        gap: .65rem;
        padding: 1.1rem 1.2rem;
    }

    .btn-save {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        background: linear-gradient(135deg,var(--g700),var(--g900));
        color: #fff;
        border: none;
        padding: .75rem 1.5rem;
        border-radius: 10px;
        font-size: .9rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(13,41,24,.25);
        transition: all .18s;
        width: 100%;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(13,41,24,.3);
            background: linear-gradient(135deg,var(--g600),var(--g800));
        }

    .btn-cancel {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        background: transparent;
        border: 1.5px solid var(--border-strong);
        color: var(--ink-muted);
        padding: .65rem 1.5rem;
        border-radius: 10px;
        font-size: .86rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .18s;
        width: 100%;
    }

        .btn-cancel:hover {
            border-color: var(--ink-faint);
            color: var(--ink);
            background: var(--surface);
        }

    .save-note {
        text-align: center;
        font-size: .71rem;
        color: var(--ink-faint);
        padding: 0 1.2rem .9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
    }

    @@media (max-width:920px) {
        .sc-layout {
            grid-template-columns: 1fr;
        }

        .sc-sidebar {
            position: static;
        }
    }

    @@media (max-width:640px) {
        .fg-2, .btn-slots {
            grid-template-columns: 1fr;
        }

        .sc-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width:420px) {
        .sc-section-body {
            padding: 1.1rem;
        }

        .sc-section-head {
            padding: .9rem 1.1rem;
        }
    }
