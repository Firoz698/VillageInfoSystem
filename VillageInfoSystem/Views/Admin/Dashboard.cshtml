@{
    ViewData["Title"] = "ড্যাশবোর্ড";
    Layout = "_AdminLayout";
    var recentNews = ViewBag.RecentNews as List<VillageInfoSystem.Models.News>;
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-num">@ViewBag.NewsCount</div>
        <div class="stat-label">📰 মোট সংবাদ</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@ViewBag.FacilityCount</div>
        <div class="stat-label">🏛️ সুবিধাসমূহ</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@ViewBag.CommitteeCount</div>
        <div class="stat-label">👥 কমিটি সদস্য</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@ViewBag.GalleryCount</div>
        <div class="stat-label">🖼️ গ্যালারি আইটেম</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">
    <div class="card">
        <div class="card-header">
            <div class="card-title">📰 সাম্প্রতিক সংবাদ</div>
            <a href="/Admin/NewsList" class="btn btn-primary" style="font-size:0.8rem;padding:0.4rem 0.9rem;">সব দেখুন</a>
        </div>
        <table>
            <thead><tr><th>শিরোনাম</th><th>বিভাগ</th><th>তারিখ</th><th>অবস্থা</th></tr></thead>
            <tbody>
                @if (recentNews != null)
                {
                    foreach (var n in recentNews)
                    {
                        <tr>
                            <td>@n.Icon @n.Title</td>
                            <td><span class="badge badge-gold">@n.Category</span></td>
                            <td>@n.PublishedAt.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge @(n.IsActive ? "badge-success" : "badge-danger")">@(n.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">⚡ দ্রুত লিংক</div>
        <div style="display:flex;flex-direction:column;gap:0.6rem;">
            <a href="/Admin/NewsCreate" class="btn btn-primary">➕ নতুন সংবাদ</a>
            <a href="/Admin/FacilityCreate" class="btn btn-outline">➕ নতুন সুবিধা</a>
            <a href="/Admin/CommitteeCreate" class="btn btn-outline">➕ নতুন সদস্য</a>
            <a href="/Admin/GalleryCreate" class="btn btn-outline">➕ গ্যালারি যোগ</a>
            <a href="/Admin/TickerCreate" class="btn btn-outline">➕ ব্রেকিং নিউজ</a>
            <a href="/Admin/VillageInfoEdit" class="btn btn-gold">⚙️ গ্রামের তথ্য সম্পাদনা</a>
            <a href="/" target="_blank" class="btn btn-edit">🌐 ওয়েবসাইট দেখুন</a>
        </div>
    </div>
</div>
