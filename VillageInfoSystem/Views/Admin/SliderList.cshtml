@model List<VillageInfoSystem.Models.SliderItem>
@{
    ViewData["Title"] = "স্লাইডার ম্যানেজমেন্ট";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-success mb-0">🖼️ স্লাইডার ম্যানেজমেন্ট</h4>
    <a href="/Admin/SliderCreate" class="btn btn-success">
        ➕ নতুন স্লাইড যোগ করুন
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th>ক্রম</th>
                        <th>ইমেজ</th>
                        <th>Badge</th>
                        <th>Title</th>
                        <th>Highlight</th>
                        <th>স্ট্যাটাস</th>
                        <th>অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var s in Model)
                        {
                            <tr>
                                <td>@s.SortOrder</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(s.ImagePath))
                                    {
                                        <img src="@s.ImagePath" style="width:80px;height:50px;object-fit:cover;border-radius:8px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@s.Badge</td>
                                <td>@s.Title</td>
                                <td><strong>@s.TitleHighlight</strong></td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge bg-success">সক্রিয়</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">নিষ্ক্রিয়</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Admin/SliderEdit/@s.Id" class="btn btn-sm btn-outline-primary">✏️ এডিট</a>
                                    <form method="post" action="/Admin/SliderDelete/@s.Id"
                                          style="display:inline"
                                          onsubmit="return confirm('এই স্লাইড মুছে ফেলবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger">🗑️ মুছুন</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">কোনো স্লাইড নেই। নতুন যোগ করুন।</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>