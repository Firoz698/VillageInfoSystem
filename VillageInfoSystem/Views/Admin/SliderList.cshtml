@model List<VillageInfoSystem.Models.SliderItem>
@{
    ViewData["Title"] = "স্লাইডার ম্যানেজমেন্ট";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.6rem;
    }

    .page-header-left h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: var(--green-dark);
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .page-header-left p {
        font-size: 0.84rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* ── SLIDER CARDS GRID ── */
    .slider-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.3rem;
        margin-bottom: 1.5rem;
    }

    .slider-card {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: all 0.28s;
        display: flex;
        flex-direction: column;
    }

        .slider-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
            border-color: rgba(26,107,60,0.18);
        }

    /* Thumbnail */
    .sc-thumb {
        height: 170px;
        background: linear-gradient(135deg, var(--green-dark), #2d9b5a);
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }

        .sc-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .slider-card:hover .sc-thumb img {
        transform: scale(1.06);
    }

    .sc-thumb-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: rgba(255,255,255,0.55);
    }

        .sc-thumb-placeholder .ph-icon {
            font-size: 2.5rem;
            opacity: 0.5;
        }

        .sc-thumb-placeholder span {
            font-size: 0.8rem;
        }

    /* Order badge */
    .sc-order {
        position: absolute;
        top: 10px;
        left: 10px;
        width: 30px;
        height: 30px;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(4px);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 800;
        color: white;
        border: 1px solid rgba(255,255,255,0.15);
    }

    /* Status badge on thumb */
    .sc-status-pill {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 0.22rem 0.65rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        backdrop-filter: blur(4px);
        border: 1px solid transparent;
    }

        .sc-status-pill.active {
            background: rgba(45,190,108,0.25);
            border-color: rgba(45,190,108,0.4);
            color: #a8f0c8;
        }

        .sc-status-pill.inactive {
            background: rgba(0,0,0,0.4);
            border-color: rgba(255,255,255,0.15);
            color: rgba(255,255,255,0.6);
        }

    /* Card body */
    .sc-body {
        padding: 1.1rem 1.2rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .sc-badge-pill {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.18rem 0.65rem;
        background: rgba(200,153,58,0.1);
        color: #8a6518;
        border: 1px solid rgba(200,153,58,0.2);
        border-radius: 50px;
        margin-bottom: 0.1rem;
        width: fit-content;
    }

    .sc-title {
        font-weight: 700;
        color: var(--green-dark);
        font-size: 0.95rem;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sc-highlight {
        font-size: 0.82rem;
        color: var(--green);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sc-sub {
        font-size: 0.78rem;
        color: var(--text-muted);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-top: 0.1rem;
        flex: 1;
    }

    /* Card footer / actions */
    .sc-actions {
        display: flex;
        gap: 0.55rem;
        padding: 0.85rem 1.2rem;
        border-top: 1px solid var(--border);
        background: #fafcfa;
    }

        .sc-actions .btn {
            flex: 1;
            justify-content: center;
        }

    /* ── EMPTY STATE ── */
    .empty-box {
        background: white;
        border-radius: var(--radius);
        border: 2px dashed var(--border);
        padding: 4rem 2rem;
        text-align: center;
    }

        .empty-box .eb-icon {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 1rem;
            opacity: 0.4;
        }

        .empty-box h4 {
            color: var(--green-dark);
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .empty-box p {
            color: var(--text-muted);
            font-size: 0.88rem;
            margin-bottom: 1.4rem;
        }

    /* ── STATS ROW ── */
    .slider-stats {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.4rem;
        flex-wrap: wrap;
    }

    .ss-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 1.1rem;
        background: white;
        border: 1px solid var(--border);
        border-radius: 50px;
        font-size: 0.82rem;
        color: var(--text-muted);
        box-shadow: var(--shadow-sm);
    }

        .ss-pill strong {
            color: var(--green-dark);
            font-size: 1rem;
        }

    @@media (max-width: 600px) {
        .slider-grid {
            grid-template-columns: 1fr;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<!-- ── PAGE HEADER ── -->
<div class="page-header">
    <div class="page-header-left">
        <h2>🎞️ স্লাইডার ম্যানেজমেন্ট</h2>
        <p>হোমপেজ হিরো স্লাইডারের সকল স্লাইড পরিচালনা করুন</p>
    </div>
    <a href="/Admin/SliderCreate" class="btn btn-primary">
        ➕ নতুন স্লাইড যোগ করুন
    </a>
</div>

<!-- ── STATS ROW ── */-->
@if (Model != null && Model.Any())
{
    int activeCount = Model.Count(s => s.IsActive);
    int inactiveCount = Model.Count(s => !s.IsActive);
    <div class="slider-stats">
        <div class="ss-pill">🎞️ মোট স্লাইড: <strong>@Model.Count</strong></div>
        <div class="ss-pill">✅ সক্রিয়: <strong>@activeCount</strong></div>
        @if (inactiveCount > 0)
        {
            <div class="ss-pill">⏸️ নিষ্ক্রিয়: <strong>@inactiveCount</strong></div>
        }
    </div>
}

<!-- ── SLIDER CARDS ── -->
@if (Model != null && Model.Any())
{
    <div class="slider-grid">
        @foreach (var s in Model)
        {
            <div class="slider-card">
                <!-- Thumbnail -->
                <div class="sc-thumb">
                    @if (!string.IsNullOrEmpty(s.ImagePath))
                    {
                        <img src="@s.ImagePath" alt="@s.Title" />
                    }
                    else
                    {
                        <div class="sc-thumb-placeholder">
                            <span class="ph-icon">🖼️</span>
                            <span>কোনো ইমেজ নেই</span>
                        </div>
                    }
                    <div class="sc-order">#@s.SortOrder</div>
                    <div class="sc-status-pill @(s.IsActive ? "active" : "inactive")">
                        @(s.IsActive ? "● সক্রিয়" : "○ নিষ্ক্রিয়")
                    </div>
                </div>

                <!-- Body -->
                <div class="sc-body">
                    @if (!string.IsNullOrEmpty(s.Badge))
                    {
                        <div class="sc-badge-pill">@s.Badge</div>
                    }
                    <div class="sc-title" title="@s.Title">@(string.IsNullOrEmpty(s.Title) ? "শিরোনাম নেই" : s.Title)</div>
                    @if (!string.IsNullOrEmpty(s.TitleHighlight))
                    {
                        <div class="sc-highlight">✦ @s.TitleHighlight</div>
                    }
                    @if (!string.IsNullOrEmpty(s.SubText))
                    {
                        <div class="sc-sub">@s.SubText</div>
                    }
                </div>

                <!-- Actions -->
                <div class="sc-actions">
                    <a href="/Admin/SliderEdit/@s.Id" class="btn btn-edit btn-sm">
                        ✏️ সম্পাদনা
                    </a>
                    <form method="post" action="/Admin/SliderDelete/@s.Id"
                          style="flex:1;display:flex;"
                          onsubmit="return confirm('এই স্লাইড মুছে ফেলবেন?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm" style="flex:1;justify-content:center;">
                            🗑️ মুছুন
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-box">
        <span class="eb-icon">🎞️</span>
        <h4>কোনো স্লাইড যোগ করা হয়নি</h4>
        <p>হোমপেজে সুন্দর স্লাইডশো দেখাতে নতুন স্লাইড যোগ করুন।</p>
        <a href="/Admin/SliderCreate" class="btn btn-primary">➕ প্রথম স্লাইড যোগ করুন</a>
    </div>
}
