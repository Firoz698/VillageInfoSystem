@model List<VillageInfoSystem.Models.GalleryItem>
@{
    ViewData["Title"] = "গ্যালারি ব্যবস্থাপনা";
    Layout = "_AdminLayout";
}
<div class="card">
    <div class="card-header">
        <div class="card-title">🖼️ গ্যালারি (@Model.Count টি)</div>
        <a href="/Admin/GalleryCreate" class="btn btn-primary">➕ নতুন যোগ</a>
    </div>
    <table>
        <thead><tr><th>আইকন</th><th>শিরোনাম</th><th>ছবি</th><th>ফিচার্ড</th><th>অবস্থা</th><th>কার্যক্রম</th></tr></thead>
        <tbody>
            @foreach (var g in Model)
            {
                <tr>
                    <td style="font-size:1.4rem">@g.Icon</td>
                    <td>@g.Title</td>
                    <td>@(string.IsNullOrEmpty(g.ImagePath) ? "—" : "✅ আপলোড করা")</td>
                    <td>@(g.IsFeatured ? "⭐" : "—")</td>
                    <td><span class="badge @(g.IsActive ? "badge-success" : "badge-danger")">@(g.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")</span></td>
                    <td style="white-space:nowrap">
                        <a href="/Admin/GalleryEdit/@g.Id" class="btn btn-edit" style="padding:0.3rem 0.65rem;font-size:0.78rem;">✏️</a>
                        <form method="post" action="/Admin/GalleryDelete/@g.Id" style="display:inline;" onsubmit="return confirm('মুছে ফেলবেন?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger" style="padding:0.3rem 0.65rem;font-size:0.78rem;">🗑️</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
