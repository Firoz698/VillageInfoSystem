@model VillageInfoSystem.Models.SliderItem
@{
    ViewData["Title"] = "স্লাইড সম্পাদনা করুন";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* ── SHARED FORM STYLES (same as SliderCreate) ── */
    .form-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.6rem;
    }

    .fph-left h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: var(--green-dark);
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .fph-left p {
        font-size: 0.84rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .form-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.4rem;
        align-items: start;
    }

    .form-section {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

        .form-section:last-child {
            margin-bottom: 0;
        }

    .fs-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: #fafcfa;
    }

    .fs-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        background: var(--green-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .fs-header h3 {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--green-dark);
    }

    .fs-header p {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .fs-body {
        padding: 1.3rem 1.4rem;
    }

    .field-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .field-grid-4 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        margin-bottom: 1.1rem;
    }

        .form-group:last-child {
            margin-bottom: 0;
        }

    .form-label {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-weight: 600;
        color: var(--green-dark);
        margin-bottom: 0.42rem;
        font-size: 0.84rem;
    }

    .req {
        color: #e74c3c;
        font-size: 0.75rem;
    }

    .form-control {
        width: 100%;
        padding: 0.68rem 0.95rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        font-family: 'Hind Siliguri', sans-serif;
        font-size: 0.9rem;
        color: var(--text);
        background: white;
        transition: all 0.2s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(26,107,60,0.09);
        }

        .form-control::placeholder {
            color: #b5c8ba;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 90px;
    }

    .field-hint {
        font-size: 0.74rem;
        color: var(--text-muted);
        margin-top: 0.28rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .validation-msg {
        font-size: 0.75rem;
        color: #c0392b;
        margin-top: 0.25rem;
    }

    .toggle-wrap {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        background: #f8fbf8;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .toggle-wrap:hover {
            border-color: var(--green);
            background: #f0f8f3;
        }

    .toggle-switch {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }

        .toggle-switch input {
            display: none;
        }

    .toggle-track {
        position: absolute;
        inset: 0;
        background: #dde8dd;
        border-radius: 50px;
        transition: background 0.25s;
        cursor: pointer;
    }

    .toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        background: white;
        border-radius: 50%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.15);
        transition: transform 0.25s;
    }

    .toggle-switch input:checked ~ .toggle-track {
        background: var(--green);
    }

    .toggle-switch input:checked ~ .toggle-thumb {
        transform: translateX(20px);
    }

    .toggle-info strong {
        display: block;
        font-size: 0.86rem;
        color: var(--green-dark);
        font-weight: 700;
    }

    .toggle-info span {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* Upload zone */
    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 1.3rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s;
        position: relative;
        background: #fafcfa;
    }

        .upload-zone:hover, .upload-zone.dragover {
            border-color: var(--green);
            background: rgba(26,107,60,0.04);
        }

        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .uz-icon {
        font-size: 1.8rem;
        display: block;
        margin-bottom: 0.4rem;
    }

    .uz-text {
        font-size: 0.83rem;
        color: var(--text-muted);
    }

        .uz-text strong {
            color: var(--green);
        }

    .uz-hint {
        font-size: 0.72rem;
        color: #b5c8ba;
        margin-top: 0.2rem;
    }

    .img-preview-wrap {
        display: none;
        margin-top: 1rem;
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid var(--border);
    }

        .img-preview-wrap img {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            display: block;
        }

        .img-preview-wrap.show {
            display: block;
        }

    .img-remove-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 28px;
        height: 28px;
        background: rgba(231,76,60,0.85);
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 0.85rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

        .img-remove-btn:hover {
            background: #c0392b;
        }

    /* Current image */
    .current-img-box {
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid var(--border);
        margin-bottom: 1rem;
        position: relative;
    }

        .current-img-box img {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
            display: block;
        }

    .ci-bar {
        background: rgba(0,0,0,0.55);
        color: rgba(255,255,255,0.8);
        font-size: 0.72rem;
        padding: 0.35rem 0.8rem;
        text-align: center;
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
    }

    .ci-change-note {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.77rem;
        color: var(--text-muted);
        background: #f5f8f5;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.55rem 0.8rem;
        margin-bottom: 0.85rem;
    }

    /* Sidebar */
    .sidebar-card {
        background: white;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

        .sidebar-card:last-child {
            margin-bottom: 0;
        }

    .sc-hd {
        padding: 0.9rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: #fafcfa;
        font-size: 0.86rem;
        font-weight: 700;
        color: var(--green-dark);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .sc-bd {
        padding: 1.1rem 1.2rem;
    }

    /* Live preview */
    .live-preview {
        border-radius: 12px;
        overflow: hidden;
        height: 160px;
        background: linear-gradient(135deg, var(--green-dark), #2d9b5a);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 1.2rem;
    }

    .lp-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transition: opacity 0.3s;
    }

        .lp-bg.show {
            opacity: 1;
        }

    .lp-overlay {
        position: absolute;
        inset: 0;
        background: rgba(8,40,24,0.6);
    }

    .lp-content {
        position: relative;
        z-index: 2;
    }

    .lp-badge {
        display: inline-block;
        background: rgba(200,153,58,0.25);
        border: 1px solid rgba(200,153,58,0.5);
        color: #e8b84b;
        padding: 0.15rem 0.65rem;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 700;
        margin-bottom: 0.45rem;
    }

    .lp-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        color: white;
        font-weight: 900;
        line-height: 1.2;
    }

        .lp-title span {
            color: #e8b84b;
        }

    .lp-sub {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.65);
        margin-top: 0.3rem;
    }

    /* Edit ID badge */
    .edit-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.8rem;
        background: rgba(26,107,60,0.07);
        border: 1px solid rgba(26,107,60,0.15);
        border-radius: 50px;
        font-size: 0.76rem;
        color: var(--green-dark);
        font-weight: 600;
    }

    .form-actions {
        display: flex;
        gap: 0.7rem;
        padding: 1.1rem 1.2rem;
        border-top: 1px solid var(--border);
        background: #fafcfa;
    }

        .form-actions .btn {
            flex: 1;
            justify-content: center;
        }

    @@media (max-width: 900px) {
        .form-layout {
            grid-template-columns: 1fr;
        }

        .field-grid-4 {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 560px) {
        .field-grid-2, .field-grid-4 {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- ── HEADER ── -->
<div class="form-page-header">
    <div class="fph-left">
        <h2>✏️ স্লাইড সম্পাদনা করুন</h2>
        <p>বিদ্যমান স্লাইডের তথ্য আপডেট করুন</p>
    </div>
    <div style="display:flex;align-items:center;gap:0.8rem;flex-wrap:wrap;">
        <div class="edit-id-badge">🆔 স্লাইড #@Model.Id</div>
        <a href="/Admin/SliderList" class="btn btn-outline btn-sm">← ফিরে যান</a>
    </div>
</div>

<form method="post" enctype="multipart/form-data" id="sliderForm">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ImagePath" type="hidden" id="existingImagePath" />

    <div class="form-layout">

        <!-- ── LEFT ── -->
        <div>
            <!-- Basic Info -->
            <div class="form-section">
                <div class="fs-header">
                    <div class="fs-icon">🏷️</div>
                    <div><h3>মূল তথ্য</h3><p>স্লাইডের শিরোনাম ও badge সম্পাদনা করুন</p></div>
                </div>
                <div class="fs-body">
                    <div class="field-grid-2">
                        <div class="form-group">
                            <label class="form-label">Badge টেক্সট <span class="req">*</span></label>
                            <input asp-for="Badge" class="form-control" id="badgeInput" oninput="updatePreview()" />
                            <span asp-validation-for="Badge" class="validation-msg"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">ক্রম নম্বর</label>
                            <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                            <div class="field-hint">ℹ️ ছোট সংখ্যা আগে দেখাবে</div>
                        </div>
                    </div>
                    <div class="field-grid-2">
                        <div class="form-group">
                            <label class="form-label">Title <span class="req">*</span></label>
                            <input asp-for="Title" class="form-control" id="titleInput" oninput="updatePreview()" />
                            <span asp-validation-for="Title" class="validation-msg"></span>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Title Highlight <span class="req">*</span></label>
                            <input asp-for="TitleHighlight" class="form-control" id="highlightInput" oninput="updatePreview()" />
                            <span asp-validation-for="TitleHighlight" class="validation-msg"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">সাব টেক্সট</label>
                        <textarea asp-for="SubText" class="form-control" rows="2" id="subInput" oninput="updatePreview()"></textarea>
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div class="form-section">
                <div class="fs-header">
                    <div class="fs-icon">🔗</div>
                    <div><h3>বাটন কনফিগারেশন</h3><p>স্লাইডের বাটন টেক্সট ও লিংক সম্পাদনা করুন</p></div>
                </div>
                <div class="fs-body">
                    <div class="field-grid-4">
                        <div class="form-group">
                            <label class="form-label">বাটন ১ লেখা</label>
                            <input asp-for="Btn1Text" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">বাটন ১ লিংক</label>
                            <input asp-for="Btn1Link" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">বাটন ২ লেখা</label>
                            <input asp-for="Btn2Text" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">বাটন ২ লিংক</label>
                            <input asp-for="Btn2Link" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Image -->
            <div class="form-section">
                <div class="fs-header">
                    <div class="fs-icon">🖼️</div>
                    <div><h3>ব্যাকগ্রাউন্ড ইমেজ</h3><p>নতুন ইমেজ আপলোড করুন বা বিদ্যমানটি রাখুন</p></div>
                </div>
                <div class="fs-body">
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="current-img-box" id="currentImgBox">
                            <img src="@Model.ImagePath" alt="বর্তমান ইমেজ" id="currentImg" />
                            <div class="ci-bar">📸 বর্তমান ইমেজ</div>
                        </div>
                        <div class="ci-change-note">
                            ℹ️ নতুন ইমেজ না দিলে বর্তমান ইমেজটি অটোমেটিক থাকবে
                        </div>
                    }
                    <div class="upload-zone" id="uploadZone">
                        <input type="file" name="imageFile" id="imageInput"
                               accept="image/*" onchange="handleImageChange(this)" />
                        <span class="uz-icon">📤</span>
                        <div class="uz-text"><strong>নতুন ইমেজ বেছে নিন</strong> বা এখানে টেনে আনুন</div>
                        <div class="uz-hint">JPG, PNG, WEBP · সর্বোচ্চ 5MB</div>
                    </div>
                    <div class="img-preview-wrap" id="previewWrap">
                        <img id="imgPreview" src="" alt="নতুন ইমেজ প্রিভিউ" />
                        <button type="button" class="img-remove-btn" onclick="removeImage()" title="সরান">✕</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── RIGHT SIDEBAR ── -->
        <div>
            <!-- Live Preview -->
            <div class="sidebar-card">
                <div class="sc-hd">👁️ লাইভ প্রিভিউ</div>
                <div class="sc-bd">
                    <div class="live-preview">
                        <div class="lp-bg" id="lpBg"
                             @(!string.IsNullOrEmpty(Model.ImagePath) ? $"style=\"background-image:url('{Model.ImagePath}');opacity:1;\"" : "")>
                        </div>
                        <div class="lp-overlay"></div>
                        <div class="lp-content">
                            <div class="lp-badge" id="lpBadge">@(Model.Badge ?? "Badge")</div>
                            <div class="lp-title" id="lpTitle">
                                @(Model.Title ?? "Title") <span id="lpHighlight">@(Model.TitleHighlight ?? "Highlight")</span>
                            </div>
                            <div class="lp-sub" id="lpSub">@(Model.SubText?.Substring(0, Math.Min(Model.SubText?.Length ?? 0, 80)) ?? "সাব টেক্সট")</div>
                        </div>
                    </div>
                    <div class="field-hint" style="margin-top:0.6rem;">ℹ️ তথ্য পরিবর্তন করলে প্রিভিউ আপডেট হবে</div>
                </div>
            </div>

            <!-- Active Toggle -->
            <div class="sidebar-card">
                <div class="sc-hd">⚙️ স্ট্যাটাস</div>
                <div class="sc-bd">
                    <label class="toggle-wrap" for="IsActive">
                        <div class="toggle-switch">
                            <input asp-for="IsActive" type="checkbox" id="IsActive" />
                            <div class="toggle-track"></div>
                            <div class="toggle-thumb" id="toggleThumb"
                                 style="@(Model.IsActive ? "transform:translateX(20px)" : "")"></div>
                        </div>
                        <div class="toggle-info">
                            <strong>স্লাইড সক্রিয় রাখুন</strong>
                            <span>বন্ধ করলে ওয়েবসাইটে দেখাবে না</span>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="sidebar-card" style="border-color:rgba(231,76,60,0.2);">
                <div class="sc-hd" style="color:#c0392b;background:#fdf5f5;border-color:rgba(231,76,60,0.15);">⚠️ ডিলিট জোন</div>
                <div class="sc-bd">
                    <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.9rem;">এই স্লাইড স্থায়ীভাবে মুছে ফেলতে নিচের বাটনে ক্লিক করুন।</p>
                    <form method="post" action="/Admin/SliderDelete/@Model.Id"
                          onsubmit="return confirm('এই স্লাইড মুছে ফেলবেন? এটি পূর্বাবস্থায় ফেরানো যাবে না।')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm" style="width:100%;justify-content:center;">
                            🗑️ স্লাইড মুছুন
                        </button>
                    </form>
                </div>
            </div>

            <!-- Submit -->
            <div class="sidebar-card">
                <div class="form-actions">
                    <a href="/Admin/SliderList" class="btn btn-outline">বাতিল</a>
                    <button type="submit" class="btn btn-primary">💾 আপডেট করুন</button>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    function updatePreview() {
        const badge = document.getElementById('badgeInput')?.value || 'Badge';
        const title = document.getElementById('titleInput')?.value || 'Title';
        const highlight = document.getElementById('highlightInput')?.value || 'Highlight';
        const sub = document.getElementById('subInput')?.value || 'সাব টেক্সট';
        document.getElementById('lpBadge').textContent = badge;
        document.getElementById('lpTitle').childNodes[0].nodeValue = title + ' ';
        document.getElementById('lpHighlight').textContent = highlight;
        document.getElementById('lpSub').textContent = sub.substring(0, 80);
    }

    function handleImageChange(input) {
        if (input.files && input.files[0]) {
            const file = input.files[0];
            if (file.size > 5 * 1024 * 1024) {
                alert('ফাইলের সাইজ ৫MB-এর বেশি হওয়া যাবে না।');
                input.value = '';
                return;
            }
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('imgPreview').src = e.target.result;
                document.getElementById('previewWrap').classList.add('show');
                document.getElementById('lpBg').style.backgroundImage = `url('${e.target.result}')`;
                document.getElementById('lpBg').style.opacity = '1';
                // Hide old current image box
                const cib = document.getElementById('currentImgBox');
                if (cib) cib.style.opacity = '0.5';
                document.getElementById('uploadZone').style.display = 'none';
            };
            reader.readAsDataURL(file);
        }
    }

    function removeImage() {
        document.getElementById('imageInput').value = '';
        document.getElementById('imgPreview').src = '';
        document.getElementById('previewWrap').classList.remove('show');
        document.getElementById('uploadZone').style.display = 'block';
        const cib = document.getElementById('currentImgBox');
        if (cib) { cib.style.opacity = '1'; }
        // Restore original bg in preview
        const origPath = document.getElementById('existingImagePath')?.value;
        if (origPath) {
            document.getElementById('lpBg').style.backgroundImage = `url('${origPath}')`;
        } else {
            document.getElementById('lpBg').style.opacity = '0';
        }
    }

    /* Drag and drop */
    const zone = document.getElementById('uploadZone');
    if (zone) {
        zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
        zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
        zone.addEventListener('drop', e => {
            e.preventDefault(); zone.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                document.getElementById('imageInput').files = e.dataTransfer.files;
                handleImageChange(document.getElementById('imageInput'));
            }
        });
    }

    /* Toggle */
    document.getElementById('IsActive')?.addEventListener('change', function() {
        document.getElementById('toggleThumb').style.transform = this.checked ? 'translateX(20px)' : '';
    });

    /* Init preview state */
    window.addEventListener('DOMContentLoaded', () => {
        const lpBg = document.getElementById('lpBg');
        if (lpBg && lpBg.style.backgroundImage) lpBg.style.opacity = '1';
    });
</script>
