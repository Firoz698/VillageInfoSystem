@model VillageInfoSystem.Models.TickerNews
@{
    ViewData["Title"] = "নতুন ব্রেকিং নিউজ";
    Layout = "_AdminLayout";
}
<div class="breadcrumb"><a href="/Admin/TickerList">ব্রেকিং নিউজ</a> › নতুন</div>
<div class="card" style="max-width:600px">
    <div class="card-title" style="margin-bottom:1.2rem">📺 নতুন টিকার যোগ</div>
    <form asp-action="TickerCreate" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label asp-for="Text"></label><textarea asp-for="Text" class="form-control" placeholder="স্ক্রলিং নিউজ টেক্সট লিখুন..."></textarea><span asp-validation-for="Text" style="color:red;font-size:0.82rem"></span></div>
        <div class="form-grid">
            <div class="form-group"><label asp-for="SortOrder"></label><input asp-for="SortOrder" type="number" class="form-control" /></div>
            <div class="form-group" style="display:flex;align-items:center;padding-top:1.8rem">
                <div class="form-check"><input asp-for="IsActive" type="checkbox" /><label asp-for="IsActive">সক্রিয়</label></div>
            </div>
        </div>
        <div style="display:flex;gap:1rem"><button type="submit" class="btn btn-primary">💾 সংরক্ষণ</button><a href="/Admin/TickerList" class="btn btn-outline">বাতিল</a></div>
    </form>
</div>
