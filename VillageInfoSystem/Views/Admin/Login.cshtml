@{
    ViewData["Title"] = "অ্যাডমিন লগইন";
    Layout = null;
}
<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>অ্যাডমিন লগইন - খোকসা মল্লিক পাড়া গ্রাম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #1a6b3c;
            --green-dark: #0f4226;
            --green-deeper: #082818;
            --green-light: #2d9b5a;
            --gold: #c8993a;
            --gold-light: #e8b84b;
            --cream: #faf6ef;
            --white: #ffffff;
            --danger: #e74c3c;
            --danger-bg: #fdf0ef;
            --text-muted: #7a8f7d;
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: 'Hind Siliguri', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            background: var(--green-deeper);
            overflow: hidden;
        }

        /* ── LEFT PANEL ── */
        .left-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            background: linear-gradient(145deg, var(--green-deeper) 0%, #0d3520 40%, #1a5c35 100%);
        }

            .left-panel::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(45,155,90,0.18) 0%, transparent 70%);
                top: -150px;
                left: -150px;
                animation: pulse 6s ease-in-out infinite;
            }

            .left-panel::after {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(200,153,58,0.12) 0%, transparent 70%);
                bottom: -100px;
                right: -100px;
                animation: pulse 6s ease-in-out infinite 3s;
            }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 0.8;
            }

            50% {
                transform: scale(1.08);
                opacity: 1;
            }
        }

        .hex-grid {
            position: absolute;
            inset: 0;
            overflow: hidden;
            opacity: 0.06;
        }

        .hex {
            position: absolute;
            width: 80px;
            height: 92px;
            background: var(--green-light);
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            animation: hexFloat linear infinite;
        }

        @@keyframes hexFloat {
            0% {
                transform: translateY(110vh) rotate(0deg);
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            90% {
                opacity: 1;
            }

            100% {
                transform: translateY(-110px) rotate(180deg);
                opacity: 0;
            }
        }

        .left-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 400px;
        }

        .village-icon {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin: 0 auto 1.8rem;
            box-shadow: 0 0 0 15px rgba(200,153,58,0.1), 0 0 0 30px rgba(200,153,58,0.05);
            animation: iconGlow 3s ease-in-out infinite;
        }

        @@keyframes iconGlow {
            0%, 100% {
                box-shadow: 0 0 0 15px rgba(200,153,58,0.1), 0 0 0 30px rgba(200,153,58,0.05);
            }

            50% {
                box-shadow: 0 0 0 20px rgba(200,153,58,0.15), 0 0 0 40px rgba(200,153,58,0.07);
            }
        }

        .left-content h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.6rem, 3vw, 2.1rem);
            color: white;
            line-height: 1.2;
            margin-bottom: 0.6rem;
            font-weight: 900;
        }

            .left-content h1 span {
                color: var(--gold-light);
            }

        .left-content p {
            color: rgba(255,255,255,0.55);
            font-size: 0.92rem;
            line-height: 1.7;
            margin-bottom: 2.5rem;
        }

        .stats-row {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
        }

        .stat-pill {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 0.6rem 1.2rem;
            text-align: center;
        }

            .stat-pill .num {
                font-family: 'Playfair Display', serif;
                font-size: 1.1rem;
                color: var(--gold-light);
                font-weight: 700;
                display: block;
            }

            .stat-pill .lbl {
                font-size: 0.7rem;
                color: rgba(255,255,255,0.45);
            }

        .left-brand {
            position: absolute;
            bottom: 2rem;
            left: 0;
            right: 0;
            text-align: center;
            color: rgba(255,255,255,0.25);
            font-size: 0.72rem;
            z-index: 2;
        }

            .left-brand span {
                color: var(--gold-light);
                opacity: 0.6;
            }

        /* ── RIGHT PANEL ── */
        .right-panel {
            width: 480px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: var(--cream);
            padding: 3rem 3rem;
            position: relative;
            overflow-y: auto;
        }

            .right-panel::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 5px;
                background: linear-gradient(90deg, var(--green), var(--gold), var(--green-light));
            }

        .login-header {
            margin-bottom: 2.2rem;
        }

        .login-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: rgba(26,107,60,0.08);
            border: 1px solid rgba(26,107,60,0.15);
            color: var(--green);
            padding: 0.28rem 0.85rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 0.9rem;
            letter-spacing: 0.04em;
        }

        .login-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.9rem;
            color: var(--green-dark);
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 0.4rem;
        }

        .login-header p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* ALERT */
        .alert {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.85rem 1rem;
            background: var(--danger-bg);
            border: 1px solid rgba(231,76,60,0.2);
            border-left: 4px solid var(--danger);
            border-radius: 10px;
            margin-bottom: 1.5rem;
            font-size: 0.88rem;
            color: #c0392b;
            animation: shakeIn 0.4s ease;
        }

        @@keyframes shakeIn {
            0%, 100% {
                transform: translateX(0);
            }

            20%, 60% {
                transform: translateX(-6px);
            }

            40%, 80% {
                transform: translateX(6px);
            }
        }

        /* FORM */
        .form-group {
            margin-bottom: 1.3rem;
            position: relative;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-weight: 600;
            color: var(--green-dark);
            font-size: 0.85rem;
            margin-bottom: 0.45rem;
        }

            .form-label .label-icon {
                font-size: 0.85rem;
                opacity: 0.7;
            }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1rem;
            pointer-events: none;
            color: var(--text-muted);
            transition: color 0.2s;
        }

        .form-input {
            width: 100%;
            padding: 0.85rem 1rem 0.85rem 2.8rem;
            border: 1.5px solid #d4e4d8;
            border-radius: 12px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 0.95rem;
            color: #1c2b1e;
            background: white;
            transition: all 0.25s;
        }

            .form-input::placeholder {
                color: #b0c0b5;
            }

            .form-input:focus {
                outline: none;
                border-color: var(--green);
                box-shadow: 0 0 0 4px rgba(26,107,60,0.08);
            }

        /* password toggle */
        .toggle-pass {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            color: var(--text-muted);
            padding: 0;
            line-height: 1;
            transition: color 0.2s;
        }

            .toggle-pass:hover {
                color: var(--green);
            }

        /* REMEMBER ME */
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.6rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .remember-wrap {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            cursor: pointer;
            user-select: none;
        }

            .remember-wrap input[type="checkbox"] {
                display: none;
            }

        .custom-checkbox {
            width: 20px;
            height: 20px;
            border: 2px solid #c5d8c9;
            border-radius: 6px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }

            .custom-checkbox .check-mark {
                opacity: 0;
                transform: scale(0.5);
                transition: all 0.2s;
                font-size: 0.7rem;
                color: white;
            }

        .remember-wrap input[type="checkbox"]:checked ~ .custom-checkbox {
            background: var(--green);
            border-color: var(--green);
        }

            .remember-wrap input[type="checkbox"]:checked ~ .custom-checkbox .check-mark {
                opacity: 1;
                transform: scale(1);
            }

        .remember-label {
            font-size: 0.86rem;
            color: #4a6350;
            font-weight: 500;
        }

        .forgot-link {
            font-size: 0.84rem;
            color: var(--green);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

            .forgot-link:hover {
                color: var(--green-light);
            }

        /* LOGIN BTN */
        .btn-login {
            width: 100%;
            padding: 0.95rem;
            background: linear-gradient(135deg, var(--green-dark), var(--green-light));
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            letter-spacing: 0.02em;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            box-shadow: 0 6px 24px rgba(15,66,38,0.35);
        }

            .btn-login::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, var(--green-light), var(--green));
                opacity: 0;
                transition: opacity 0.3s;
            }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 32px rgba(15,66,38,0.45);
            }

                .btn-login:hover::before {
                    opacity: 1;
                }

            .btn-login span, .btn-login .btn-icon {
                position: relative;
                z-index: 1;
            }

            .btn-login:active {
                transform: translateY(0);
            }

            .btn-login.loading .btn-text {
                display: none;
            }

            .btn-login .spinner {
                display: none;
                width: 20px;
                height: 20px;
                border: 2px solid rgba(255,255,255,0.4);
                border-top-color: white;
                border-radius: 50%;
                animation: spin 0.7s linear infinite;
            }

            .btn-login.loading .spinner {
                display: block;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* DIVIDER */
        .divider {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            margin: 1.4rem 0;
            color: #b5c9ba;
            font-size: 0.78rem;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e0ece3;
            }

        /* SECURITY BADGE */
        .security-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.7rem 1rem;
            background: rgba(26,107,60,0.05);
            border: 1px solid rgba(26,107,60,0.1);
            border-radius: 10px;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

            .security-badge .lock {
                font-size: 0.85rem;
            }

        /* BACK LINK */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 1.5rem;
            color: var(--text-muted);
            font-size: 0.84rem;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

            .back-link:hover {
                color: var(--green);
            }

        /* RESPONSIVE */
        @@media (max-width: 820px) {
            body {
                flex-direction: column;
                overflow: auto;
            }

            .left-panel {
                min-height: 260px;
                padding: 2rem;
            }

                .left-panel::before, .left-panel::after {
                    display: none;
                }

            .stats-row {
                display: none;
            }

            .village-icon {
                width: 72px;
                height: 72px;
                font-size: 2rem;
                margin-bottom: 1rem;
            }

            .left-content h1 {
                font-size: 1.4rem;
            }

            .left-content p {
                display: none;
            }

            .right-panel {
                width: 100%;
                min-height: auto;
                padding: 2rem 1.5rem 3rem;
            }
        }

        @@media (max-width: 480px) {
            .right-panel {
                padding: 1.5rem 1.2rem 2.5rem;
            }

            .login-header h2 {
                font-size: 1.6rem;
            }
        }

        /* FADE IN */
        .fade-up {
            animation: fadeUp 0.5s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up:nth-child(1) {
            animation-delay: 0.05s;
        }

        .fade-up:nth-child(2) {
            animation-delay: 0.1s;
        }

        .fade-up:nth-child(3) {
            animation-delay: 0.15s;
        }

        .fade-up:nth-child(4) {
            animation-delay: 0.2s;
        }

        .fade-up:nth-child(5) {
            animation-delay: 0.25s;
        }

        .fade-up:nth-child(6) {
            animation-delay: 0.3s;
        }

        .fade-up:nth-child(7) {
            animation-delay: 0.35s;
        }
    </style>
</head>
<body>

    <!-- ── LEFT DECORATIVE PANEL ── -->
    <div class="left-panel">
        <div class="hex-grid" aria-hidden="true">
            <div class="hex" style="left:10%;animation-duration:14s;animation-delay:0s;opacity:0.8;"></div>
            <div class="hex" style="left:30%;animation-duration:18s;animation-delay:3s;width:50px;height:58px;"></div>
            <div class="hex" style="left:55%;animation-duration:12s;animation-delay:6s;"></div>
            <div class="hex" style="left:75%;animation-duration:20s;animation-delay:1.5s;width:60px;height:69px;"></div>
            <div class="hex" style="left:85%;animation-duration:16s;animation-delay:9s;width:45px;height:52px;"></div>
            <div class="hex" style="left:20%;animation-duration:22s;animation-delay:4s;width:35px;height:40px;"></div>
        </div>

        <div class="left-content">
            <div class="village-icon">🌿</div>
            <h1>খোকসা <span>মল্লিক পাড়া</span> গ্রাম</h1>
            <p>আপনার গ্রামের ডিজিটাল তথ্য পোর্টালে স্বাগতম।<br>অ্যাডমিন প্যানেল থেকে সকল তথ্য পরিচালনা করুন।</p>
            <div class="stats-row">
                <div class="stat-pill">
                    <span class="num">৫+</span>
                    <span class="lbl">বিভাগ</span>
                </div>
                <div class="stat-pill">
                    <span class="num">১০০%</span>
                    <span class="lbl">নিরাপদ</span>
                </div>
                <div class="stat-pill">
                    <span class="num">২৪/৭</span>
                    <span class="lbl">সক্রিয়</span>
                </div>
            </div>
        </div>

        <div class="left-brand">
            Developed by <span>Md. Shakil</span>
        </div>
    </div>

    <!-- ── RIGHT LOGIN PANEL ── -->
    <div class="right-panel">

        <div class="login-header fade-up">
            <div class="login-tag">🔐 সুরক্ষিত প্রবেশ</div>
            <h2>স্বাগতম!</h2>
            <p>অ্যাডমিন প্যানেলে প্রবেশ করতে লগইন করুন</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert fade-up">
                <span>⚠️</span>
                <span>@ViewBag.Error</span>
            </div>
        }

        <form method="post" id="loginForm">
            @Html.AntiForgeryToken()

            <div class="form-group fade-up">
                <label class="form-label">
                    <span class="label-icon">👤</span> ইউজারনেম
                </label>
                <div class="input-wrap">
                    <input type="text"
                           name="username"
                           id="username"
                           class="form-input"
                           placeholder="ইউজারনেম লিখুন"
                           required
                           autofocus
                           autocomplete="username" />
                    <span class="input-icon" aria-hidden="true">👤</span>
                </div>
            </div>

            <div class="form-group fade-up">
                <label class="form-label">
                    <span class="label-icon">🔑</span> পাসওয়ার্ড
                </label>
                <div class="input-wrap">
                    <input type="password"
                           name="password"
                           id="password"
                           class="form-input"
                           placeholder="••••••••"
                           required
                           autocomplete="current-password"
                           style="padding-right:3rem;" />
                    <span class="input-icon" aria-hidden="true">🔑</span>
                    <button type="button" class="toggle-pass" onclick="togglePassword()" title="পাসওয়ার্ড দেখুন">
                        <span id="eyeIcon">👁️</span>
                    </button>
                </div>
            </div>

            <!-- REMEMBER ME -->
            <div class="form-options fade-up">
                <label class="remember-wrap" id="rememberLabel">
                    <input type="checkbox" name="rememberMe" id="rememberMe" />
                    <span class="custom-checkbox">
                        <span class="check-mark">✓</span>
                    </span>
                    <span class="remember-label">আমাকে মনে রাখুন</span>
                </label>
                <a href="#" class="forgot-link">পাসওয়ার্ড ভুলে গেছেন?</a>
            </div>

            <button type="submit" class="btn-login fade-up" id="loginBtn">
                <span class="btn-icon">🔐</span>
                <span class="btn-text">লগইন করুন</span>
                <div class="spinner"></div>
            </button>
        </form>

        <div class="divider fade-up">অথবা</div>

        <div class="security-badge fade-up">
            <span class="lock">🛡️</span>
            <span>SSL এনক্রিপ্টেড ও সুরক্ষিত সংযোগ</span>
        </div>

        <a href="/" class="back-link fade-up">
            ← মূল সাইটে ফিরুন
        </a>

    </div>

    <script>
        /* ── Password toggle ── */
        function togglePassword() {
            const input = document.getElementById('password');
            const icon  = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = '🙈';
            } else {
                input.type = 'password';
                icon.textContent = '👁️';
            }
        }

        /* ── Remember Me: restore on page load ── */
        (function () {
            const saved = localStorage.getItem('rm_user');
            if (saved) {
                document.getElementById('username').value    = saved;
                document.getElementById('rememberMe').checked = true;
            }
        })();

        /* ── Custom checkbox toggle (click on label area) ── */
        document.getElementById('rememberLabel').addEventListener('click', function (e) {
            // Let the native <input type="checkbox"> inside handle its own click
            // Only intercept clicks NOT on the input itself
            if (e.target.tagName !== 'INPUT') {
                e.preventDefault();
                const cb = document.getElementById('rememberMe');
                cb.checked = !cb.checked;
            }
        });

        /* ── Form submit: save/clear username & show loading ── */
        document.getElementById('loginForm').addEventListener('submit', function () {
            const cb = document.getElementById('rememberMe');
            const un = document.getElementById('username').value.trim();

            if (cb.checked && un) {
                localStorage.setItem('rm_user', un);
            } else {
                localStorage.removeItem('rm_user');
            }

            // Loading state
            const btn = document.getElementById('loginBtn');
            btn.classList.add('loading');
            btn.disabled = true;
        });
    </script>
</body>
</html>
