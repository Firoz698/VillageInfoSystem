@{
    ViewData["Title"] = "অ্যাডমিন লগইন";
    Layout = null;
}
<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>অ্যাডমিন লগইন - খোকসা মল্লিক পাড়া গ্রাম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Hind Siliguri', sans-serif;
            background: linear-gradient(135deg, #0f4226, #1a6b3c);
            min-height: 100vh;
            display: grid;
            place-items: center;
        }

        .login-box {
            background: white;
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 1.8rem;
        }

            .login-logo .icon {
                font-size: 3rem;
            }

            .login-logo h1 {
                font-size: 1.4rem;
                color: #0f4226;
                margin-top: 0.5rem;
                font-weight: 700;
            }

            .login-logo p {
                color: #888;
                font-size: 0.85rem;
                margin-top: 4px;
            }

        .form-group {
            margin-bottom: 1.1rem;
        }

        label {
            display: block;
            font-weight: 600;
            color: #1a6b3c;
            margin-bottom: 0.35rem;
            font-size: 0.88rem;
        }

        input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #dde8dd;
            border-radius: 10px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 0.95rem;
        }

            input:focus {
                outline: none;
                border-color: #1a6b3c;
                box-shadow: 0 0 0 3px rgba(26,107,60,0.1);
            }

        .btn-login {
            width: 100%;
            padding: 0.85rem;
            background: linear-gradient(135deg, #1a6b3c, #2d9b5a);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            margin-top: 0.5rem;
        }

            .btn-login:hover {
                opacity: 0.92;
            }

        .alert {
            padding: 0.75rem 1rem;
            background: #fdeaea;
            color: #c0392b;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.88rem;
        }

        .hint {
            text-align: center;
            margin-top: 1.2rem;
            font-size: 0.8rem;
            color: #aaa;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 1rem;
            color: #1a6b3c;
            font-size: 0.85rem;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="login-logo">
            <div class="icon">🌿</div>
            <h1>খোকসা মল্লিক পাড়া গ্রাম</h1>
            <p>অ্যাডমিন প্যানেলে লগইন করুন</p>
        </div>
        @if (ViewBag.Error != null)
        {
            <div class="alert">⚠️ @ViewBag.Error</div>
        }
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>ইউজারনেম</label>
                <input type="text" name="username" placeholder="admin" required autofocus />
            </div>
            <div class="form-group">
                <label>পাসওয়ার্ড</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-login">🔐 লগইন করুন</button>
        </form>
        <div class="hint">Default: admin / Admin@1234</div>
        <a href="/" class="back-link">← মূল সাইটে ফিরুন</a>
    </div>
</body>
</html>
