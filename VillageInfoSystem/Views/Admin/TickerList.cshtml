@model List<VillageInfoSystem.Models.TickerNews>
@{
    ViewData["Title"] = "ব্রেকিং নিউজ";
    Layout = "_AdminLayout";
}

<style>
    :root {
        --primary: #1a3a5c;
        --primary-light: #2563a8;
        --red: #c0392b;
        --red-soft: #fff1f0;
        --red-border: #f8bcb7;
        --success: #1a7a4a;
        --danger: #b53a2e;
        --surface: #ffffff;
        --surface-alt: #f5f7fa;
        --border: #dde3ec;
        --text-main: #1a2636;
        --text-muted: #5a6b80;
        --shadow-sm: 0 2px 8px rgba(26,58,92,0.07);
        --shadow-md: 0 6px 24px rgba(26,58,92,0.12);
        --radius: 12px;
    }

    .page-wrapper {
        animation: fadeUp 0.4s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Live ticker preview bar ── */
    .ticker-preview {
        background: linear-gradient(90deg, var(--red) 0%, #a52820 100%);
        border-radius: var(--radius);
        margin-bottom: 1.75rem;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(192,57,43,0.22);
        display: flex;
        align-items: stretch;
        min-height: 46px;
    }

    .ticker-label {
        background: rgba(0,0,0,0.25);
        color: #fff;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.45rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

        .ticker-label .dot {
            width: 7px;
            height: 7px;
            background: #ff6b6b;
            border-radius: 50%;
            animation: pulse 1.2s ease-in-out infinite;
        }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.75);
        }
    }

    .ticker-scroll-wrapper {
        flex: 1;
        overflow: hidden;
        display: flex;
        align-items: center;
        position: relative;
    }

        .ticker-scroll-wrapper::before,
        .ticker-scroll-wrapper::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            width: 40px;
            z-index: 1;
            pointer-events: none;
        }

        .ticker-scroll-wrapper::before {
            left: 0;
            background: linear-gradient(to right, rgba(160,40,32,0.6), transparent);
        }

        .ticker-scroll-wrapper::after {
            right: 0;
            background: linear-gradient(to left, rgba(160,40,32,0.6), transparent);
        }

    .ticker-scroll {
        display: flex;
        align-items: center;
        gap: 3rem;
        white-space: nowrap;
        animation: scrollTicker 22s linear infinite;
        padding: 0 1rem;
        color: #fff;
        font-size: 0.84rem;
        font-weight: 500;
        letter-spacing: 0.01em;
    }

        .ticker-scroll:hover {
            animation-play-state: paused;
        }

    @@keyframes scrollTicker {
        0% {
            transform: translateX(100%);
        }

        100% {
            transform: translateX(-100%);
        }
    }

    .ticker-sep {
        opacity: 0.4;
    }

    /* ── Page header ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .page-header-left h1 {
        font-family: 'Noto Serif Bengali', Georgia, serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
        margin: 0 0 0.2rem;
    }

    .page-header-left p {
        font-size: 0.82rem;
        color: var(--text-muted);
        margin: 0;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--primary);
        color: #fff;
        text-decoration: none;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        box-shadow: 0 2px 8px rgba(26,58,92,0.18);
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        white-space: nowrap;
    }

        .btn-add:hover {
            background: var(--primary-light);
            transform: translateY(-1px);
            box-shadow: 0 5px 18px rgba(26,58,92,0.22);
        }

    /* ── Stats ── */
    .stats-bar {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        box-shadow: var(--shadow-sm);
        transition: box-shadow 0.2s;
    }

        .stat-card:hover {
            box-shadow: var(--shadow-md);
        }

    .stat-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-muted);
        margin-bottom: 0.3rem;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--primary);
        line-height: 1;
    }

    .stat-card.success .stat-value {
        color: var(--success);
    }

    .stat-card.danger .stat-value {
        color: var(--danger);
    }

    /* ── Table card ── */
    .table-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }

    .table-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface-alt);
    }

    .search-box {
        position: relative;
        display: flex;
        align-items: center;
    }

        .search-box svg {
            position: absolute;
            left: 0.75rem;
            color: var(--text-muted);
            pointer-events: none;
        }

        .search-box input {
            padding: 0.45rem 0.9rem 0.45rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-size: 0.84rem;
            background: var(--surface);
            width: 220px;
            outline: none;
            color: var(--text-main);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

            .search-box input:focus {
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(37,99,168,0.12);
            }

    .table-count {
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .table-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    table.data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        color: var(--text-main);
    }

        table.data-table thead th {
            background: var(--surface-alt);
            padding: 0.75rem 1rem;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

            table.data-table thead th.center {
                text-align: center;
            }

        table.data-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }

            table.data-table tbody tr:last-child {
                border-bottom: none;
            }

            table.data-table tbody tr:hover {
                background: #f0f5fb;
            }

        table.data-table td {
            padding: 0.9rem 1rem;
            vertical-align: middle;
        }

            table.data-table td.center {
                text-align: center;
            }

    /* ── Order badge ── */
    .order-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: #eff4ff;
        border: 1px solid #c5d7f8;
        color: #2b5aad;
        font-size: 0.8rem;
        font-weight: 700;
    }

    /* ── News text cell ── */
    .news-text-cell {
        max-width: 420px;
    }

    .news-text {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.55;
        color: var(--text-main);
    }

    /* ── Badges ── */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.28rem 0.7rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
    }

        .badge::before {
            content: '';
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

    .badge-success {
        background: #ecfdf3;
        color: #1a7a4a;
        border: 1px solid #a7e6c3;
    }

        .badge-success::before {
            background: #1a7a4a;
        }

    .badge-danger {
        background: #fff1f0;
        color: #b53a2e;
        border: 1px solid #f8bcb7;
    }

        .badge-danger::before {
            background: #b53a2e;
        }

    /* ── Delete button ── */
    .btn-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        background: #fff1f0;
        border: 1px solid #f8bcb7;
        color: #b53a2e;
        border-radius: 7px;
        padding: 0.38rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, transform 0.12s;
        white-space: nowrap;
    }

        .btn-delete:hover {
            background: #ffe3e0;
            border-color: #f5a09a;
            transform: translateY(-1px);
        }

    /* ── Mobile cards ── */
    .mobile-list {
        display: none;
    }

    .news-card {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 0.9rem;
        align-items: flex-start;
        transition: background 0.15s;
    }

        .news-card:last-child {
            border-bottom: none;
        }

        .news-card:hover {
            background: #f0f5fb;
        }

    .news-card-body {
        flex: 1;
        min-width: 0;
    }

    .news-card-text {
        font-size: 0.88rem;
        line-height: 1.55;
        color: var(--text-main);
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .news-card-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    /* ── Empty ── */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
    }

        .empty-state .empty-icon {
            font-size: 2.8rem;
            display: block;
            margin-bottom: 0.75rem;
            opacity: 0.5;
        }

        .empty-state p {
            margin: 0 0 1.5rem;
            font-size: 0.9rem;
        }

    @@media (max-width: 768px) {
        .desktop-table {
            display: none;
        }

        .mobile-list {
            display: block;
        }

        .stats-bar {
            grid-template-columns: repeat(3, 1fr);
            gap: 0.65rem;
        }

        .stat-card {
            padding: 0.75rem 1rem;
        }

        .stat-value {
            font-size: 1.35rem;
        }

        .search-box input {
            width: 160px;
        }

        .btn-add span {
            display: none;
        }

        .ticker-scroll {
            font-size: 0.78rem;
        }
    }

    @@media (max-width: 480px) {
        .stats-bar {
            grid-template-columns: 1fr 1fr;
        }

            .stats-bar .stat-card:last-child {
                grid-column: 1 / -1;
            }
    }
</style>

<div class="page-wrapper">

    <!-- Live Ticker Preview -->
    @if (Model.Any(t => t.IsActive))
    {
        <div class="ticker-preview">
            <div class="ticker-label">
                <span class="dot"></span>
                লাইভ
            </div>
            <div class="ticker-scroll-wrapper">
                <div class="ticker-scroll">
                    @foreach (var t in Model.Where(t => t.IsActive).OrderBy(t => t.SortOrder))
                    {
                        <span>@t.Text</span>
                        <span class="ticker-sep">◆</span>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Header -->
    <div class="page-header">
        <div class="page-header-left">
            <h1>ব্রেকিং নিউজ টিকার</h1>
            <p>স্ক্রলিং সংবাদ টিকার পরিচালনা করুন</p>
        </div>
        <a href="/Admin/TickerCreate" class="btn-add">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            <span>নতুন টিকার যোগ</span>
        </a>
    </div>

    <!-- Stats -->
    <div class="stats-bar">
        <div class="stat-card">
            <div class="stat-label">মোট</div>
            <div class="stat-value">@Model.Count</div>
        </div>
        <div class="stat-card success">
            <div class="stat-label">সক্রিয়</div>
            <div class="stat-value">@Model.Count(t => t.IsActive)</div>
        </div>
        <div class="stat-card danger">
            <div class="stat-label">নিষ্ক্রিয়</div>
            <div class="stat-value">@Model.Count(t => !t.IsActive)</div>
        </div>
    </div>

    <!-- Table -->
    <div class="table-card">
        <div class="table-toolbar">
            <div class="search-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="সংবাদ খুঁজুন…" id="searchInput" oninput="filterRows()" />
            </div>
            <span class="table-count" id="countLabel">@Model.Count টি সংবাদ</span>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">📺</span>
                <p>এখনও কোনো ব্রেকিং নিউজ যোগ করা হয়নি।</p>
                <a href="/Admin/TickerCreate" class="btn-add">প্রথম টিকার যোগ করুন</a>
            </div>
        }
        else
        {
            <!-- Desktop -->
            <div class="table-scroll desktop-table">
                <table class="data-table" id="tickerTable">
                    <thead>
                        <tr>
                            <th class="center" style="width:60px">ক্রম</th>
                            <th>সংবাদ টেক্সট</th>
                            <th class="center" style="width:110px">অবস্থা</th>
                            <th class="center" style="width:100px">কার্যক্রম</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @foreach (var t in Model.OrderBy(t => t.SortOrder))
                        {
                            <tr data-text="@t.Text.ToLower()">
                                <td class="center"><span class="order-chip">@t.SortOrder</span></td>
                                <td class="news-text-cell"><div class="news-text">@t.Text</div></td>
                                <td class="center">
                                    <span class="badge @(t.IsActive ? "badge-success" : "badge-danger")">
                                        @(t.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")
                                    </span>
                                </td>
                                <td class="center">
                                    <form method="post" action="/Admin/TickerDelete/@t.Id" style="display:inline" onsubmit="return confirmDelete()">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                                            মুছুন
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile -->
            <div class="mobile-list" id="mobileList">
                @foreach (var t in Model.OrderBy(t => t.SortOrder))
                {
                    <div class="news-card" data-text="@t.Text.ToLower()">
                        <div class="order-chip" style="margin-top:2px;flex-shrink:0">@t.SortOrder</div>
                        <div class="news-card-body">
                            <div class="news-card-text">@t.Text</div>
                            <div class="news-card-meta">
                                <span class="badge @(t.IsActive ? "badge-success" : "badge-danger")">
                                    @(t.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")
                                </span>
                                <form method="post" action="/Admin/TickerDelete/@t.Id" style="display:inline;margin-left:auto" onsubmit="return confirmDelete()">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /></svg>
                                        মুছুন
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function confirmDelete() {
        return confirm('এই সংবাদটি স্থায়ীভাবে মুছে ফেলবেন?');
    }

    function filterRows() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('#tableBody tr');
        const cards = document.querySelectorAll('#mobileList .news-card');
        let count = 0;
        rows.forEach(r => {
            const match = r.dataset.text.includes(q);
            r.style.display = match ? '' : 'none';
            if (match) count++;
        });
        cards.forEach(c => {
            c.style.display = c.dataset.text.includes(q) ? '' : 'none';
        });
        document.getElementById('countLabel').textContent = `${count} টি সংবাদ`;
    }
</script>
