<!-- ═══ HERO SLIDER ═══ -->
<div id="home">
    @if (sliders != null && sliders.Any())
    {
        bool isFirst = true;
        foreach (var slide in sliders)
        {
            <div class="slide @(isFirst ? "active" : "")">
                @if (!string.IsNullOrEmpty(slide.ImagePath))
                {
                    <div class="slide-bg" style="background-image:url('@slide.ImagePath');"></div>
                    <div class="slide-overlay"></div>
                }
                <div class="blob b1"></div>
                <div class="blob b2"></div>
                <div class="blob b3"></div>
                <div class="slide-content">
                    <div class="slide-badge">@slide.Badge</div>
                    <h1 class="slide-title">@slide.Title<br><span>@slide.TitleHighlight</span></h1>
                    <p class="slide-sub">@slide.SubText</p>
                    <div class="slide-btns">
                        @if (!string.IsNullOrEmpty(slide.Btn1Text))
                        {
                            <a href="@slide.Btn1Link" class="btn btn-primary">@slide.Btn1Text</a>
                        }
                        @if (!string.IsNullOrEmpty(slide.Btn2Text))
                        {
                            <a href="@slide.Btn2Link" class="btn btn-outline">@slide.Btn2Text</a>
                        }
                    </div>
                </div>
            </div>
            isFirst = false;
        }
    }
    else
    {
        <!-- Default slide if no sliders configured -->
        <div class="slide active">
            <div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div>
            <div class="slide-content">
                <div class="slide-badge">🌿 স্বাগতম</div>
                <h1 class="slide-title">খোকসা <span>মল্লিক পাড়া</span></h1>
                <p class="slide-sub">সবুজে ঘেরা শান্তির গ্রাম — খুলনা বিভাগ, বাংলাদেশ</p>
                <div class="slide-btns">
                    <a href="#about" class="btn btn-primary">গ্রামের পরিচিতি</a>
                    <a href="#news" class="btn btn-outline">সর্বশেষ সংবাদ</a>
                </div>
            </div>
        </div>
    }

    <div class="s-arrow s-prev" onclick="changeSlide(-1)" aria-label="আগের স্লাইড">&#8592;</div>
    <div class="s-arrow s-next" onclick="changeSlide(1)" aria-label="পরের স্লাইড">&#8594;</div>
    <div class="s-counter"><b id="curNum">1</b> / <span id="totalNum">@slideCount</span></div>
    <div class="s-dots" id="dotsContainer">
        @for (int i = 0; i < slideCount; i++)
        {
            <div class="dot @(i == 0 ? "active" : "")" onclick="goTo(@i)"></div>
        }
    </div>
    <div class="s-progress" id="sProgress"></div>
    <div class="s-dev">✦ Developed by <span>Md Firoz Ali</span></div>
    <a href="#news" class="scroll-arrow" aria-label="নিচে স্ক্রোল করুন">⬇</a>
</div>

<!-- ═══ NEWS ═══ -->
<section id="news">
    <div class="container">
        <div class="section-header reveal">
            <div class="section-tag">📰 গ্রামের সংবাদ</div>
            <h2 class="section-title">সর্বশেষ খবর ও ঘটনাবলি</h2>
            <p class="section-desc">খোকসা মল্লিক পাড়া গ্রামের সাম্প্রতিক খবর, উন্নয়ন ও বিভিন্ন অনুষ্ঠানের বিবরণ</p>
            <div class="divider"></div>
        </div>
        <div class="news-grid">
            @if (featuredNews != null)
            {
                <div class="news-featured reveal">
                    <div class="nf-img">
                        <div class="nf-cat">⭐ শীর্ষ সংবাদ</div>
                        <div class="nf-img-icon">@featuredNews.Icon</div>
                    </div>
                    <div class="nf-body">
                        <div class="nf-date">📅 @featuredNews.PublishedAt.ToString("dd MMMM, yyyy")</div>
                        <h3>@featuredNews.Title</h3>
                        <p>@featuredNews.Description</p>
                        <a href="#" class="nf-more">বিস্তারিত পড়ুন →</a>
                    </div>
                </div>
            }
            <div class="news-list">
                @if (newsList != null && newsList.Any())
                {
                    foreach (var n in newsList)
                    {
                        <div class="ni reveal">
                            <div class="ni-icon">@n.Icon</div>
                            <div class="ni-body">
                                <div class="ni-cat">@n.Category</div>
                                <h4>@n.Title</h4>
                                <span class="ni-date">📅 @n.PublishedAt.ToString("dd MMMM, yyyy")</span>
                            </div>
                        </div>
                    }
                }
                else if (featuredNews == null)
                {
                    <div style="text-align:center;padding:3rem;color:var(--text-light);">
                        <div style="font-size:3rem;margin-bottom:1rem;">📭</div>
                        <p>এখনো কোনো সংবাদ যোগ করা হয়নি।</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

